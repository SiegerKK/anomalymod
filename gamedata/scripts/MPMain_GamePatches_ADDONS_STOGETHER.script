            end
            if netid then GameManager:OnICustomScriptAction("ui_stove_furniture", "SyncStash", serialize_table_simple(m_data.stove_stashes), false, netid) end
            return se_inv_box and se_inv_box.id or nil
        end
        function ui_stove_furniture.UICookStove:AccessStash()
            local stash_id = ui_stove_furniture.GetStash(self.obj_id)
