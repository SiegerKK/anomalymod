        function ui_stove_furniture.UICookStove:OpenCookUI()
            local obj = level.object_by_id(self.obj_id)
            if IIsHost() then
                item_cooking.start(obj, "fieldcooker")
                self:Close()
                return true
            end
            local stash_id = ui_stove_furniture.GetStash(self.obj_id)
