            if grok_additional_storyline_npc_invincible.ads_npcs[npc:section()] == 1 then
                if IsActor(shit.draftsman) then
                    local com1 = db.actor:id() == shit.draftsman:id() and get_actor_true_community() or nil
                    if game_relations.is_factions_enemies(com1 or character_community(shit.draftsman), character_community(npc)) then
                        shit.power = shit.power * 0.10
