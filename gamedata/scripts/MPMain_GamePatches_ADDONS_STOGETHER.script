    if operacia_monolith then
        operacia_monolith.timer = 0
        operacia_monolith.actor_on_update = function ()
            if not IIsHost() then return end

            -- Timed checks. Why that idk.
            local tg = time_global()
            if operacia_monolith.timer - tg < 2000 then return end
            operacia_monolith.timer = tg

            -- TM get class
            local tm = task_manager.get_task_manager()
            if not tm then return end

            -- We check all players for item.
            -- cs informer pda
            if xr_conditions.actor_has_item(db.actor, db.actor, { "cs_informer_pda" }) and 
                not has_alife_info("cs_task2_start") and has_alife_info("cs_task1_start") then
                db.actor:give_info_portion("cs_task2_start")
                tm:give_task("cs_story_task2")
                return
            end
            -- bar case
            if xr_conditions.actor_has_item(db.actor, db.actor, { "bar_case" }) and not has_alife_info("bar_case_have") then
		        db.actor:give_info_portion("bar_case_have")
                alife_create("snork_cs_strong",vector():set(-61.414897918701,1.2449436187744,-148.25701904297),39582,2223)
                alife_create("m_controller_normal2",vector():set(-38.140983581543,0.48093682527542,-146.32695007324),50578,2258)
                return
            end
            -- cs deshefrator
            if xr_conditions.actor_has_item(db.actor, db.actor, { "cs_deshefrator" }) and not has_alife_info("cs_task8_storytask_start") then
                tm:give_task("cs_task8_storytask")	
                news_manager.send_tip(db.actor, game.translate_string("cs_task8_news3"), 1, nil, 15000)
                db.actor:give_info_portion("cs_task8_storytask_start")
                return
            end
            -- pda shmatko
            if xr_conditions.actor_has_item(db.actor, db.actor, { "pda_shmatko" }) and not has_alife_info("dolg_story_task_3_dop_started") then
                tm:give_task("dolg_story_task_3_dop")			
                db.actor:give_info_portion("dolg_story_task_3_dop_started")
                return
            end
            -- pda pinya
            if xr_conditions.actor_has_item(db.actor, db.actor, { "pda_pinya" }) and not has_alife_info("dolg_story_task_4_dop_started") then
                tm:give_task("dolg_story_task_4_dop")			
                db.actor:give_info_portion("dolg_story_task_4_dop_started")
                return
            end
            -- pda barbos
            if xr_conditions.actor_has_item(db.actor, db.actor, { "pda_barbos" }) and not has_alife_info("pda_barbos_found") then
                db.actor:give_info_portion("pda_barbos_found")
                alife_create("snork_cs_strong",vector():set(-15.210734367371,-2.5547621250153,-219.93609619141),52999,2764)
                return
            end
            -- pda tango
            if xr_conditions.actor_has_item(db.actor, db.actor, { "pda_tango" }) and not has_alife_info("pda_tango_found") then
                db.actor:give_info_portion("pda_tango_found")
                alife_create("bloodsucker_cs_normal",vector():set(116.27769470215,-2.9433076381683,-314.80520629883),102209,2785)		
                return
            end
            -- pda tribun
            if db.actor:object("pda_tribun") and not has_alife_info("pda_tribun_found") then
                db.actor:give_info_portion("pda_tribun_found")
                alife_create("burer_cs_normal",vector():set(176.04179382324,-0.21944612264633,-207.09704589844),116088,2805)		
                return
            end
            -- some conditions 4 zaver
            if has_alife_info("kuznecov_task_4_zavercheno") and has_alife_info("document_x10_kuznecov") and not has_alife_info("come_to_aes_vidan") then
                tm:give_task("come_to_aes")
                news_manager.send_tip(db.actor, game.translate_string("kvartet_1"), 4, army, 30000)
                db.actor:give_info_portion("come_to_aes_vidan")
                return
            end
            -- some defense sq for assault
            if has_alife_info("monolith_defense_squad_1_death") and has_alife_info("monolith_defense_squad_2_death") and 
                has_alife_info("monolith_defense_squad_3_death") and not has_alife_info("road_clear") then
                db.actor:give_info_portion("road_clear")
                tm:give_task("assault_gen")
                news_manager.send_tip(db.actor, game.translate_string("kvartet_3"), 4, army, 30000)
                return
            end
            -- sq defense quest done
            if has_alife_info("monolith_defense_squad_gen_death") and not has_alife_info("zadacha_vipolnena") then
                db.actor:give_info_portion("zadacha_vipolnena")
                news_manager.send_tip(db.actor, game.translate_string("kvartet_4"), 4, army, 30000)
                return
            end
            -- SQ alife
            if has_alife_info("mil_smart_terrain_7_7_freedom_leader_stalker_squad_dead") and not has_alife_info("zadacha_vipolnena_1") then
                db.actor:give_info_portion("zadacha_vipolnena_1")
                news_manager.send_tip(db.actor, game.translate_string("st_cherep_1"), 4, nil, 30000)
                return
            end
            -- Check time or kill the informer...
            if hours >= 21 and hours < 23 and not has_alife_info("cs_task1_start") and has_alife_info("cs_story_task0_done") then
                news_manager.send_tip(db.actor, game.translate_string("cs_task1_news"), 4, csky, 30000)
                news_manager.send_tip(db.actor, game.translate_string("cs_task1_news1"), 7, csky, 30000)
                db.actor:give_info_portion("cs_task1_start")
                tm:give_task("cs_story_task1")
                -- Spawn and call function logic of se obj
                local se_obj = alife_create("cs_informer",vector():set(105.97696685791,1.1209254264832,332.66290283203),201708,84)
                if se_obj then se_obj:on_death() else printf("![ERROR] Failed to create 'cs_informer'!") end
            elseif hours >= 12 and hours < 22 and not has_alife_info("holod_soobshil") and has_alife_info("cs_story_task2_done") then
                news_manager.send_tip(db.actor, game.translate_string("cs_task1_news2"), 1, csky, 30000)
                db.actor:give_info_portion("holod_soobshil")
                tm:give_task("cs_story_task3_start")
            elseif hours >= 5 and hours < 12 and not has_alife_info("cs1_fail") and has_alife_info("cs_task1_start") then
		        db.actor:give_info_portion("cs1_fail")
            end
        end
    end
end

