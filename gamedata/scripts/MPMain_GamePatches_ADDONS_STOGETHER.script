            if not raid_notebook_gui.GUI then return end
            return raid_notebook_gui.GUI
        end
        raid_notebook_gui.remote_raid_block_item = function (i)
            local GUIS = raid_notebook_gui.get_ui_silent()
            if not GUIS then return end
            printf("[Server] Player bough item from notebook of host!")
            local ItemsTBL = raid_notebook_gui_items.raid_items[i]
            ItemsTBL.tmr = utils_data.CTime_to_table(game.get_game_time())
            GUIS:UpdateItemsMenu()
        end
        raid_notebook_gui.LTX_GLOBAL = ini_file("misc\\task\\tm_raid_tasks.ltx")
        raid_notebook_gui.request_tasks_data = function (PlayerNetID)
            local GUIS = raid_notebook_gui.get_ui_silent()
            if not GUIS then return end
            printf("[Server] Player request tasks from notebook of host!")
            local task_id = GUIS.task_conts[1] and GUIS.task_conts[1].task_sec
            if not (task_id and raid_notebook_gui.LTX_GLOBAL:section_exist(task_id)) then
                GUIS:UpdateTaskMenu()
            end
            GameManager:OnICustomScriptAction("raid_notebook_gui", "receive_tasks_data", serialize_table_simple(raid_tasks_main.raid_tasks_t) , false, PlayerNetID)
        end
        raid_notebook_gui.remote_raid_accept_quest = function (i)
            local GUIS = raid_notebook_gui.get_ui_silent()
            if not GUIS then return end
            if not IIsHost() then
                printf("[Client] Received packet that quest %s num was took by client(s)", i)
                -- Search section by idx
                local section = GUIS.task_conts[i] and GUIS.task_conts[i].task_sec
                if not (section and raid_notebook_gui.LTX_GLOBAL:section_exist(section)) then
                    printf("! Task section: [%s] does not exist", section)
                    return
                end
                -- Iterate and active flag set
                local ActiveIDX = 999
                for comm, t in pairs(raid_tasks_main.raid_tasks_t) do
                    local taskdata = t.tasks[section]
                    if taskdata and not taskdata.active then
                        taskdata.active = true
                        ActiveIDX = taskdata.gui_index
                        break
                    end
                end
                -- Iterate and move
                for comm, t in pairs(raid_tasks_main.raid_tasks_t) do
                    for sec, taskdata in pairs(t.tasks) do
                        if sec ~= section and taskdata.gui_index > ActiveIDX then
                            taskdata.gui_index = taskdata.gui_index - 1
                        end
                    end
                end
                -- Update Tasks Menu for clear accepted task
                local scroll_pos = GUIS.task_scroll:GetCurrentScrollPos()
                GUIS:UpdateTaskMenu()
			    GUIS.task_scroll:SetScrollPos(scroll_pos)
                return
            end
            printf("[Server] Player sent need to take a quest under [%i] num ", i)
            GUIS:OnAcceptTask(i)
            GameManager:OnICustomScriptAction("raid_notebook_gui", "remote_raid_accept_quest", tostring(i), false)
        end
        raid_notebook_gui.remote_raid_perf_upgrade = function (i)
            printf("[Server] Player sent need to get upgrade under [%i] num ", i)
            local UpgradeTBL = raid_notebook_gui_shelter.raid_shelter_upgrades[i]
            local funcerman = raid_notebook_gui_shelter[UpgradeTBL.func]
            if type(funcerman) ~= "function" then
                printe("! Failed to call upgrade: " .. tostring(UpgradeTBL.func))
                return
            end
            UpgradeTBL.active = true
            if IIsHost() then funcerman() end
        end
        -- Both sides... Need to im lock item
        function raid_notebook_gui.RaidNotebook:OnBuyUpgrade(i)
            local UpgradeTBL = raid_notebook_gui_shelter.raid_shelter_upgrades[i]
            if db.actor:money() < UpgradeTBL.cost then return end
		    db.actor:give_money(-UpgradeTBL.cost)
            -- Set flags or call func if need
            raid_notebook_gui.remote_raid_perf_upgrade(i)
            -- sync bough upgrade
            GameManager:OnICustomScriptAction("raid_notebook_gui", "remote_raid_perf_upgrade", tostring(i), false)
            self:UpdateShelterMenu()
        end
        function raid_notebook_gui.RaidNotebook:OnBuyItem(i)
            local ItemsTBL = raid_notebook_gui_items.raid_items[i]
            local funcerman = raid_notebook_gui_items[ItemsTBL.func]
            xr_sound.set_sound_play(db.actor:id(), "raid_click_2")	
            if db.actor:money() < ItemsTBL.cost then return end
            db.actor:give_money(-ItemsTBL.cost)
            ItemsTBL.tmr = utils_data.CTime_to_table(game.get_game_time())
            funcerman()
            -- Sync flag
            GameManager:OnICustomScriptAction("raid_notebook_gui", "remote_raid_block_item", tostring(i), false)
            -- Update UI
            self:UpdateItemsMenu()
        end
    end
    if raid_utils then
