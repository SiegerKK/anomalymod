local function DNEWGETCOM(npc, default)
    local blacklisted_comms = {
        ["trader"] = true,
        ["monster"] = true
    }
    local furniture = {
        ["esc_m_trader"] = true,
        ["red_m_lesnik"] = true
    }
    if furniture[npc:name()] then return "stalker" end
    local community = character_community(npc)
    if not blacklisted_comms[community] then return community end
    local sq = get_object_squad(npc)
    local squad_community = sq and sq:get_squad_community()
    if squad_community and not blacklisted_comms[squad_community] then return squad_community end
    return default or "stalker"
end

function engine_perform_special_addon_sync(id, ToPlayerNetID)
    CreateTimeEvent(id, "send_special_addons_sync", 0.1, function ()
        if magazines then
            local mag_data = magazines.get_mag_data(id)
            if not mag_data then return true end
            local payload = { GameManager:GetServerIDByLocalID(id), { #mag_data.loaded, mag_data.loaded[1] } }
            GameManager:OnICustomScriptAction("magazines", "remote_set_mag_or_ammo", serialize_table_simple(payload), false, ToPlayerNetID or 0)
        end
        return true
    end)
end

local MCMSetting = reworked_rf_receiver_mcm and reworked_rf_receiver_mcm.get_config("only_equip_rf") or false
function addoned_rf_client()
    -- Raid to grim rf receiver beeper
    if raid_tasks_main and raid_tasks_main.raid_active_tasks then
        -- From slot or active detector object
        local obj_det = MCMSetting and db.actor:item_in_slot(9) or db.actor:active_detector()
        if not (obj_det and sound_source and obj_det:section() == "detector_radio") then return true end
        -- Search the raid quest points
        for k, v in pairs(raid_tasks_main.raid_active_tasks) do
            if v and v.target_freq and v.target_position and v.level_name then
                local mpos = vector():set(v.target_position[1], v.target_position[2], v.target_position[3])
                local dist = db.actor:position():distance_to(mpos)
                if dist < 250 and v.level_name == level.name() then
                    MPMain_RF_Receiver_STOGETHER.set_beep_freq(dist)
                    local dist_ratio = dist / 250
                    local pass_range = item_radio.is_in_range(v.target_freq)
                    local vol_range = item_radio.get_vol_range(v.target_freq)
                    local vol_signal = pass_range and clamp((1 - dist_ratio) * vol_range, 0, 1) or 0
                    sound_source:play(db.actor, 0, sound_object.s2d)
                    sound_source.volume = vol_signal
                end
            end
        end
        return true
    end
    return false
end

function ui_workshop.UIWorkshopCraft:addoned_uicraft()
    -- CHECK BEHAVIOUR
    if not zz_item_artefact then return false end
    -- This array will contain the craft items to despawn haha.
    local payload = {}

    -- GAMMA variables, used for artefact crafting sorry i dunno how it;s works...
    local total_cond = 0
    local counter = 0
    local randomize = 0
    local randomina = zz_item_artefact.arti_min_eff or 30
    local randomaxa = zz_item_artefact.arti_max_eff or 44

    -- Check condition and other parameters
    for i = 1, #self.craft_item do
        -- Calc craft item to be in list it;s easier sync instead of other...
        if #self.craft_item[i] > 0 then
            for j = 1, #self.craft_item[i] do
                local item_id = self.craft_item[i][j]
                local obj = level.object_by_id(item_id)
                local obj_p = obj and obj:parent()
                if obj_p then
                    local kindergarden = SYS_GetParam(0, obj:section(), "kind")
                    if kindergarden == "i_arty_junk" then
                        total_cond = 1
                        counter = 1
                        randomize = 1
                    elseif kindergarden == "i_arty" then
                        total_cond = total_cond + obj:condition()
                        counter = counter + 1
                        randomize = 0
                    end
                    if obj_p:id() == db.actor:id() or IIsHost() then
                        alife_release(obj)
                    elseif obj_p:id() ~= 0 then
                        payload[#payload + 1] = GameManager:GetServerIDByLocalID(item_id)
                    end
                end
            end
        end

        -- Perform special sync when discharge tools...
        local remain = self.craft_item_remain[i]
        if remain and remain.id and remain.cnt then
            local obj_itm = level.object_by_id(remain.id)
            if obj_itm then
                if utils_item.discharge(obj_itm, remain.cnt) ~= 0 then
                    MPMain_GamePatches_STOGETHER.engine_perform_special_sync(remain.id)
                else
                    payload[#payload + 1] = GameManager:GetServerIDByLocalID(remain.id)
                end
            end
        end
    end

    -- Increase Statistic
    game_statistics.increment_statistic("items_crafted")

    -- Effect
    actor_effects.play_item_fx("craft_dummy")

    -- Craft item that we decide
    local crafto = self.craft_item_r[1]
    local params = self.craft_item_r[2]
    if IsItem("ammo", crafto) then
        alife_create_item(crafto, db.actor, { ammo = params })
    else
        for _ = 1, params do
            local kind = SYS_GetParam(0, crafto, "kind")
            if kind == "i_arty" or kind == "i_arty_cont" then
                if counter > 0 and total_cond > 0 then
                    local cond_to_set = total_cond / counter
                    -- GAMMA artefact overhaul: a junk ingredient rolls random effectiveness; keeps the average on plain Anomaly
                    if cond_to_set >= 0.99 then cond_to_set = 0.989 end
                    if randomize == 1 then cond_to_set = math.random(randomina, randomaxa) / 100 end
                    alife_create_item(crafto, db.actor, { cond = cond_to_set })
                end
            else
                alife_create_item(crafto, db.actor)
            end
        end
    end

    -- Sending to clients request to clear that items in ui or host do releasing
    GameManager:OnICustomScriptAction("ui_workshop", "silent_craft_item", serialize_table_simple(payload), false)

    -- LOST MODDED BEHAVIOUR AND STFU IT
    if self.last_cont and self.last_idx and self.UpdateUi then
        self.btn_craft:Enable(false)
        CreateTimeEvent("totally_not_random_event" .. time_global(), "update_ui_delay" .. time_global(), 0.1, self.UpdateUi, self, self.last_cont, self.last_idx)
    end
    return true
end

function addoned_draw_postpone_locally(task_id)
    local task_ini = task_manager.task_ini
    if igi_generic_task and igi_desscription then
        local igi_qmp_details = igi_generic_task and igi_generic_task.TASK_SETUP[task_id]
        if igi_qmp_details then
            local title, text, icon = igi_desscription.get_task_text_values(igi_qmp_details)
            return { title, text, icon , "iconed_answer_item" }
        end
    end
    -- If nta_details has super quest another like...
    local nta_details = task_ini:r_string_ex(task_id, "nta_task_details")
    if nta_details then
        local data = load_var(db.actor, task_id) or {}
        local news_text = game.translate_string(nta_details)
        local title = game.translate_string(task_ini:r_string_ex(task_id, "title") or "error")
        local icon = task_ini:r_string_ex(task_id, "icon") or "ui_iconsTotal_mutant"
        local realtbl = type(data) == "table"
        local map = realtbl and (data.lvl_target or data.target_map or data.map or data.level_name or data.lvl_task)
        local locname = map and (game.translate_string("st_location") .. ": " .. game.translate_string(map)) or ""
        if locname ~= "" then news_text = news_text .. "\\n " .. locname end
        db.actor:give_talk_message2(title, news_text, icon, "iconed_answer_item")
        return { title, news_text, icon, "iconed_answer_item" }
    end
    -- Fetch task and addoned z_fetch_shows_count
    local sec = load_var(db.actor, task_id .. "_fetch")
    if z_fetch_shows_count and sec then
        local news_caption = game.translate_string("ui_inv_needs") .. ":"
        local fetch_count = load_var(db.actor, task_id .. "_fetch_count") or 1
        local iname = game.translate_string(ini_sys:r_string_ex(sec, "inv_name") or sec)
        local extra = ""
        if (ini_sys:r_string_ex(sec, "kind") == "i_arty") then
            extra = " " .. game.translate_string("st_ui_artefact")
        end
        local clr = utils_xml.get_color("pda_white")
        local news_text = iname .. extra .. clr .. " (x" .. fetch_count .. ")"
        news_text = z_fetch_shows_count.extend_news_text(news_text, sec, fetch_count)
        local news_ico = task_manager.task_ini:r_string_ex(task_id, "icon") or "ui_inGame2_D_Sisshik"
        db.actor:give_talk_message2(news_caption, news_text, news_ico, "iconed_answer_item")
        return { news_caption, news_text, news_ico, "iconed_answer_item" }
    end
    -- Skip specials
    return MPMain_QuestPatches_STOGETHER.client_draw_postpone_locally(task_id, true)
end

function Patch()
    if not GameManager:GetFlag() then Patch_Client() end
    -- ==== Patches of launch on new aoe and off features =====
    if not _G.class_registrator_modded_exes then
        _G.class_registrator_modded_exes = {}
    end
    _G.class_registrator_modded_exes.cs_register = function(factory,client_object_class,server_object_class,clsid,script_clsid)
        factory:register(client_object_class,server_object_class,clsid,script_clsid)
    end
    _G.class_registrator_modded_exes.c_register = function(factory,client_object_class,clsid,script_clsid)
        if not editor() then factory:register(client_object_class,clsid,script_clsid) end
    end
    _G.class_registrator_modded_exes.s_register = function(factory,server_object_class,clsid,script_clsid)
        factory:register(server_object_class,clsid,script_clsid)
    end
    _G.class_registrator_modded_exes.register = function(object_factory)
        cs_register(object_factory, "CWeaponSSRS", "se_item.se_weapon_magazined", "_WP_SSRS", "wpn_ssrs_s")
    end
    -- Some missing or new db something likely
    if not (clsid.wpn_ssrs and clsid.wpn_ssrs_s) then
        clsid.wpn_ssrs = clsid.wpn_ssrs or clsid.wpn_vintorez
        clsid.wpn_ssrs_s = clsid.wpn_ssrs_s or clsid.wpn_vintorez_s
    end
    -- Imgui onrender funca
    if not axr_main["imgui_on_render"] then
        AddScriptCallback("imgui_on_render")
    end
    -- This part we fill with disable stuff which not supported in MP at all
    -- New aoe don't support this shit. Or just to disble it
    _G.se_stmgun = {}
    _G.se_projector = {}
    _G.sar_mcm_handler_mcm = {}
    _G.sar_reverb_preset = {}
    _G.sar_snd_replacer = {}
    _G.sar_main = {}
    _G.zzzz_ads_sound = {}
    _G.swm_legs = {}
    _G.npc_loot_claim = {}
    -- ==== END =====
    -- Arti jam
    if zzzz_arti_jamming_repairs then
        zzzz_arti_jamming_repairs.act_fieldstrip = function (id, part_name)
            local obj = level.object_by_id(id)
            if not obj then return end
            OLDARTISTRIP(id, part_name)
            -- Sync ejected part!
            local parent = obj:parent()
            if parent and parent:id() ~= db.actor:id() then
                local payload = string.format("%s, %s", id, part_name)
                GameManager:OnICustomScriptAction("zzzz_arti_jamming_repairs", "remote_remove_part", payload, false)
            end
        end
        zzzz_arti_jamming_repairs.remote_remove_part = function (id, part_name)
            id = id and GameManager:GetLocalIDByServerID(id)
            local part_list = item_parts.get_parts_con(level.object_by_id(id), id, false)
            if not part_list then return end
            printf("=== [Client] Someone ejected part [%u][%s] or its flag!", id, tostring(part_name))
            -- Remote remove specific part...
            if part_list[part_name] then
                printf("[Client] Part %s = ejected!", tostring(ipart_name))
                part_list[part_name] = -1
                return
            end
            -- Remove all if not selected any specific
            for ipart_name, v in pairs(part_list) do
                printf("[Client] Part %s = ejected!", tostring(ipart_name))
                part_list[ipart_name] = -1
            end
        end
        function ui_item.build_desc_header(obj, sec, str)
            local _str = ""
            local _str2 = zzzz_arti_jamming_repairs.original_build_desc_header(obj, sec, str)
            local flag = a_arti_jamming_mcm.on_key_press and a_arti_jamming_mcm.on_key_hold or zzzz_arti_jamming_repairs.get_config("display")
            if obj and IsWeapon(obj) and not IsAmmo(obj) and flag and zzzz_arti_jamming_repairs.has_parts(obj) then
                local display_str = ""
                local parts = item_parts.get_parts_con(obj, obj:id(), true) or {}
                for k, v in pairs(parts) do
                    display_str = display_str .. zzzz_arti_jamming_repairs.process_part(k, v)
                end
                _str = _str .. " " .. OLDCOLORWPOS .. game.translate_string("st_name_issues") .. "\\n" .. display_str
            end
            return _str .. _str2
        end
    end
    -- Grok shit fixes
    if grok_actor_damage_balancer then
        grok_actor_damage_balancer.premitigation = 0
    end
    -- Magazines
    if magazines then
        magazines.remote_set_mag_or_ammo = function (data)
            local id = GameManager:GetLocalIDByServerID(data[1])
            local value = data[2]
            local ammobox = data[3]
            local obj = level.object_by_id(id)
            -- Wow simplified
            if not obj then return end
            -- Set Magazine val
            if not ammobox then
                local mag_data = magazines.get_mag_data(id)
                if mag_data then
                    -- Fill mag with same type of ammo...
                    mag_data.loaded = {}
                    if value[2] then
                        for i = 1, value[1] do
                            stack.push(mag_data.loaded, value[2])
                        end
                    end
                    magazines.set_mag_data(id, mag_data)
                    magazines.timed_refresh()
                end
                return
            end
            -- Set ammo box val
            if not obj.ammo_set_count then return end
            obj:ammo_set_count(value)
        end
        -- Remote eject magazine behavior
        magazines.ejectmug_remote_event = function (id, obj)
            obj = obj or level.object_by_id(GameManager:GetLocalIDByServerID(id))
            if not (obj and obj:parent()) then return end
            if IIsHost() then return OLDEJECTMAGS(obj) end
            obj:set_ammo_elapsed(0)
            return true
        end
        magazines.eject_magazine = function (weapon, remote)
            if not (weapon and weapon:parent()) then return end
            if weapon:parent():id() == db.actor:id() then return OLDEJECTMAGS(weapon) end
            -- Send sync events
            local srvid = GameManager:GetServerIDByLocalID(weapon:id())
            GameManager:OnICustomScriptAction("magazines", "ejectmug_remote_event", tostring(srvid), false)
            return magazines.ejectmug_remote_event(weapon:id(), weapon)
        end
        -- Remote unload behavior
        local unload_in_progress = {}
        local host_unload_results = {}
        local host_unload_sessions = {}
        local host_remote_sessions = {}
        local local_unload_sessions = {}

        local function mags_mp_log(fmt, ...)
            printf(
                "! COOP: STOGETHER : MagsRedux : "
                .. fmt,
                ...
            )
        end

        local function mags_mp_active()
            return (IIsHosted and IIsHosted())
                or (IIsConnected and IIsConnected())
        end

        local function is_valid_server_id(id)
            return type(id) == "number"
        end

        local function normalize_netid(value)
            local numeric = tonumber(value)

            if numeric then
                return numeric
            end

            return tostring(value)
        end

        local function same_netid(left, right)
            return normalize_netid(left)
                == normalize_netid(right)
        end

        local function copy_loaded(loaded)
            local result = {}

            for i = 1, #(loaded or {}) do
                result[i] = loaded[i]
            end

            return result
        end

        local function get_unload_parent_kind(parent)
            if db.actor
            and parent
            and parent:id() == db.actor:id()
            then
                return "actor"
            end

            return "object"
        end

        local function finish_local_unload(magazine_server_id)
            local_unload_sessions[magazine_server_id] = nil
        end

        local function cancel_local_unload(magazine_server_id, reason)
            local session = local_unload_sessions[magazine_server_id]

            mags_mp_log(
                "session cancelled mag=%s requester=%s seq=%s expected=%s reason=%s",
                tostring(magazine_server_id),
                tostring(session and session.requester_netid),
                tostring(session and session.sequence),
                tostring(session and session.expected_count),
                tostring(reason)
            )

            finish_local_unload(magazine_server_id)
        end

        local function get_created_object_id(obj)
            if type(obj) == "number" then
                return obj
            end

            if not obj then
                return nil
            end

            local ok_field, field_id = pcall(function()
                return obj.id
            end)

            if ok_field
            and type(field_id) == "number"
            then
                return field_id
            end

            local ok_method, method_id = pcall(function()
                return obj:id()
            end)

            if ok_method
            and type(method_id) == "number"
            then
                return method_id
            end

            return nil
        end

        local function host_create_ammo_checked(ammo_section, parent, count, created_ids)
            local box_size = SYS_GetParam(2, ammo_section, "box_size", 1)
            box_size = tonumber(box_size) or 1

            if box_size < 1 then
                box_size = 1
            end

            local expected_boxes = math.ceil(count / box_size)

            local ok, created_objects = pcall(function()
                return create_ammo(
                    ammo_section,
                    parent:position(),
                    parent:level_vertex_id(),
                    parent:game_vertex_id(),
                    parent:id(),
                    count
                )
            end)

            if not ok
            or type(created_objects) ~= "table"
            then
                return false
            end

            local created_now = 0

            for _, created_object in pairs(created_objects) do
                local id = get_created_object_id(created_object)

                if not id then
                    return false
                end

                created_ids[#created_ids + 1] = id
                created_now = created_now + 1
            end

            return created_now == expected_boxes
        end

        local function host_release_created_ammo(created_ids)
            for _, id in ipairs(created_ids or {}) do
                if id then
                    pcall(
                        alife_release_id,
                        id,
                        "MagsRedux unload rollback"
                    )
                end
            end
        end

        local function host_find_credit_box(parent, ammo_section, host_session)
            local credit = host_session
                and host_session.ammo_boxes
                and host_session.ammo_boxes[ammo_section]

            if not credit
            or not credit.server_id
            then
                return nil, nil
            end

            local local_id = GameManager:GetLocalIDByServerID(credit.server_id)
            local ammo_obj = local_id and level.object_by_id(local_id)

            if not ammo_obj
            or ammo_obj:section() ~= ammo_section
            or not ammo_obj:parent()
            or ammo_obj:parent():id() ~= parent:id()
            or not ammo_obj.ammo_get_count
            or not ammo_obj.ammo_set_count
            then
                return nil, nil
            end

            local current_count = ammo_obj:ammo_get_count()

            if current_count >= credit.box_size then
                return nil, nil
            end

            return ammo_obj, credit
        end

        local function host_credit_one_round(parent, ammo_section, host_session)
            if not host_session then
                return false, nil
            end

            host_session.ammo_boxes = host_session.ammo_boxes or {}

            local box_size = SYS_GetParam(2, ammo_section, "box_size", 1)
            box_size = tonumber(box_size) or 1

            if box_size < 1 then
                box_size = 1
            end

            local ammo_obj, credit = host_find_credit_box(
                parent,
                ammo_section,
                host_session
            )

            if ammo_obj and credit then
                local old_count = ammo_obj:ammo_get_count()
                local new_count = old_count + 1
                ammo_obj:ammo_set_count(new_count)

                credit.count = new_count

                local server_id = credit.server_id

                return true, {
                    ammo_server_id = server_id,
                    old_count = old_count,
                    new_count = new_count,
                    created_new = false,
                    rollback = function()
                        pcall(function()
                            ammo_obj:ammo_set_count(old_count)
                        end)
                        credit.count = old_count
                    end
                }
            end

            local created_ids = {}
            local created = host_create_ammo_checked(
                ammo_section,
                parent,
                1,
                created_ids
            )

            if not created then
                host_release_created_ammo(created_ids)
                return false, nil
            end

            local created_id = created_ids[1]
            local server_id = GameManager:GetServerIDByLocalID(created_id) or created_id

            host_session.ammo_boxes[ammo_section] = {
                server_id = server_id,
                count = 1,
                box_size = box_size
            }

            return true, {
                ammo_server_id = server_id,
                old_count = 0,
                new_count = 1,
                created_new = true,
                rollback = function()
                    host_release_created_ammo({ created_id })
                    if host_session.ammo_boxes[ammo_section]
                    and host_session.ammo_boxes[ammo_section].server_id == server_id
                    then
                        host_session.ammo_boxes[ammo_section] = nil
                    end
                end
            }
        end

        local function sync_credited_ammo(credit)
            if not credit
            or not credit.ammo_server_id
            then
                return
            end

            local payload = {
                credit.ammo_server_id,
                credit.new_count,
                true
            }

            pcall(function()
                GameManager:OnICustomScriptAction(
                    "magazines",
                    "remote_set_mag_or_ammo",
                    serialize_table_simple(payload),
                    false
                )
            end)

            if magazines.inventory_refresh then
                pcall(magazines.inventory_refresh, 2)
            end

            pcall(magazines.timed_refresh)
        end

        local function play_unload_step_sound(magazine_server_id)
            local local_id = GameManager:GetLocalIDByServerID(magazine_server_id)
            local session = local_unload_sessions[magazine_server_id]

            if not local_id
            and session
            and session.local_magazine_id
            then
                local_id = session.local_magazine_id
            end

            local magazine = local_id and level.object_by_id(local_id)
            local parent = magazine and magazine:parent()

            if not parent then
                return false
            end

            local ok = pcall(function()
                local snd_obj = sound_object("magazines\\ammo_load"..math.random(1, 7))
                if snd_obj then
                    snd_obj:play_no_feedback(
                        parent,
                        0,
                        0,
                        parent:position(),
                        1.0,
                        1.0
                    )
                end
            end)

            return ok
        end

        local function apply_authoritative_mag_state(magazine_server_id, loaded, attempt, on_applied)
            attempt = attempt or 1

            local local_id = GameManager:GetLocalIDByServerID(magazine_server_id)
            local magazine = local_id and level.object_by_id(local_id)

            if not magazine then
                if attempt < 10 then
                    CreateTimeEvent(
                        "mag_redux",
                        "apply_mag_state_"..tostring(magazine_server_id).."_"..tostring(attempt),
                        0.1,
                        function()
                            apply_authoritative_mag_state(
                                magazine_server_id,
                                loaded,
                                attempt + 1,
                                on_applied
                            )

                            return true
                        end
                    )

                    return nil
                end

                mags_mp_log(
                    "state apply failed: magazine missing mag=%s",
                    tostring(magazine_server_id)
                )

                return false
            end

            local mag_data = magazines.get_mag_data(magazine:id())

            if not mag_data then
                if attempt < 10 then
                    CreateTimeEvent(
                        "mag_redux",
                        "apply_mag_data_"..tostring(magazine_server_id).."_"..tostring(attempt),
                        0.1,
                        function()
                            apply_authoritative_mag_state(
                                magazine_server_id,
                                loaded,
                                attempt + 1,
                                on_applied
                            )

                            return true
                        end
                    )

                    return nil
                end

                mags_mp_log(
                    "state apply failed: mag data missing mag=%s",
                    tostring(magazine_server_id)
                )

                return false
            end

            local ok_apply, apply_err = pcall(function()
                mag_data.loaded = copy_loaded(loaded)

                magazines.set_mag_data(
                    magazine:id(),
                    mag_data
                )

                magazines.timed_refresh()

                mags_mp_log(
                    "state applied mag=%s remaining=%s",
                    tostring(magazine_server_id),
                    tostring(#mag_data.loaded)
                )

                if on_applied then
                    on_applied()
                end
            end)

            if not ok_apply then
                mags_mp_log(
                    "state apply runtime error mag=%s error=%s",
                    tostring(magazine_server_id),
                    tostring(apply_err)
                )

                return false
            end

            return true
        end

        local function get_authoritative_loaded_safe(magazine)
            local ok, loaded = pcall(function()
                local data =
                    magazines.get_mag_data(
                        magazine:id()
                    )

                if not data
                or type(data.loaded) ~= "table"
                then
                    return {}
                end

                return copy_loaded(data.loaded)
            end)

            return ok and loaded or {}
        end

        local function send_unload_result(
            requester_netid,
            magazine_server_id,
            request_sequence,
            success,
            error_code,
            authoritative_loaded,
            mode,
            ammo_section
        )
            local payload = {
                requester_netid,
                magazine_server_id,
                request_sequence,
                success and true or false,
                error_code or "",
                copy_loaded(authoritative_loaded),
                mode,
                ammo_section
            }

            if same_netid(
                requester_netid,
                GameManager:GetMySNETID()
            )
            then
                mags_mp_log(
                    "local ACK dispatch requester=%s mag=%s seq=%s",
                    tostring(requester_netid),
                    tostring(magazine_server_id),
                    tostring(request_sequence)
                )

                local ack_event_id =
                    "mags_unload_local_ack_"
                    .. tostring(magazine_server_id)
                    .. "_"
                    .. tostring(request_sequence)

                CreateTimeEvent(
                    "mag_redux",
                    ack_event_id,
                    0.01,
                    function()
                        local ok, err = pcall(
                            magazines.unload_operation_result,
                            payload
                        )

                        if not ok then
                            mags_mp_log(
                                "local ACK failed mag=%s seq=%s error=%s",
                                tostring(magazine_server_id),
                                tostring(request_sequence),
                                tostring(err)
                            )

                            cancel_local_unload(
                                magazine_server_id,
                                "local ACK failed: "
                                    .. tostring(err)
                            )
                        end

                        return true
                    end
                )

                return true
            end

            local ok, err = pcall(function()
                GameManager:OnICustomScriptAction(
                    "magazines",
                    "unload_operation_result",
                    serialize_table_simple(payload),
                    false
                )
            end)

            if not ok then
                mags_mp_log(
                    "ACK transport failed requester=%s mag=%s seq=%s error=%s",
                    tostring(requester_netid),
                    tostring(magazine_server_id),
                    tostring(request_sequence),
                    tostring(err)
                )
            end

            mags_mp_log(
                "ACK sent mag=%s requester=%s seq=%s mode=%s success=%s error=%s remaining=%s",
                tostring(magazine_server_id),
                tostring(requester_netid),
                tostring(request_sequence),
                tostring(mode),
                tostring(success),
                tostring(error_code),
                tostring(#(authoritative_loaded or {}))
            )

            return ok
        end

        local function execute_host_unload_step(magazine, expected_round_count, host_session)
            local parent = magazine:parent()
            local mag_data = magazines.get_mag_data(magazine:id())

            if not parent
            or not mag_data
            or type(mag_data.loaded) ~= "table"
            then
                return false, "invalid_state"
            end

            if #mag_data.loaded == 0 then
                return false, "already_empty"
            end

            if #mag_data.loaded ~= expected_round_count then
                return false, "stale_count"
            end

            local original_loaded = copy_loaded(mag_data.loaded)
            local ammo_section = mag_data.loaded[#mag_data.loaded]

            if type(ammo_section) ~= "string"
            or ammo_section == ""
            then
                return false, "invalid_ammo"
            end

            local credited, credit = host_credit_one_round(
                parent,
                ammo_section,
                host_session
            )

            if not credited then
                return false, "ammo_credit_failed"
            end

            stack.pop(mag_data.loaded)

            local save_ok = pcall(
                magazines.set_mag_data,
                magazine:id(),
                mag_data
            )

            if not save_ok then
                if credit and credit.rollback then
                    credit.rollback()
                end

                mag_data.loaded = original_loaded
                pcall(
                    magazines.set_mag_data,
                    magazine:id(),
                    mag_data
                )
                return false, "save_failed"
            end

            sync_credited_ammo(credit)
            pcall(magazines.timed_refresh)

            return true, nil, copy_loaded(mag_data.loaded), ammo_section, credit
        end

        local function execute_host_unload_all(magazine, expected_round_count)
            local created_ids = {}
            local original_loaded = {}
            local parent
            local mag_data
            local had_rounds = false
            local state_committed = false

            local ok, err = pcall(function()
                parent = magazine:parent()

                if not parent then
                    return true
                end

                mag_data = magazines.get_mag_data(magazine:id())

                if not mag_data
                or type(mag_data.loaded) ~= "table"
                then
                    return true
                end

                if #mag_data.loaded == 0 then
                    return true
                end

                if #mag_data.loaded ~= expected_round_count then
                    return false
                end

                had_rounds = true
                original_loaded = copy_loaded(mag_data.loaded)

                local ammo_to_make = {}

                for i = 1, #original_loaded do
                    local ammo_section = original_loaded[i]

                    if type(ammo_section) ~= "string"
                    or ammo_section == ""
                    then
                        return false
                    end

                    ammo_to_make[ammo_section] =
                        (ammo_to_make[ammo_section] or 0) + 1
                end

                for ammo_section, count in pairs(ammo_to_make) do
                    local created = host_create_ammo_checked(
                        ammo_section,
                        parent,
                        count,
                        created_ids
                    )

                    if not created then
                        return false
                    end
                end

                mag_data.loaded = {}
                magazines.set_mag_data(magazine:id(), mag_data)
                state_committed = true

                return true
            end)

            if not ok
            or err == false
            then
                if not state_committed then
                    host_release_created_ammo(created_ids)

                    if mag_data
                    and had_rounds
                    then
                        mag_data.loaded = original_loaded
                        pcall(
                            magazines.set_mag_data,
                            magazine:id(),
                            mag_data
                        )
                    end
                end

                return false, "transaction_failed"
            end

            if not had_rounds then
                return false, "already_empty", {}
            end

            pcall(magazines.timed_refresh)

            return true, nil, {}, nil
        end

        local function execute_host_remote_unload_step(shadow, expected_round_count)
            if not shadow
            or type(shadow.loaded) ~= "table"
            then
                return false, "invalid_shadow"
            end

            if #shadow.loaded == 0 then
                return false, "already_empty", copy_loaded(shadow.loaded)
            end

            if #shadow.loaded ~= expected_round_count then
                return false, "stale_count", copy_loaded(shadow.loaded)
            end

            local ammo_section = shadow.loaded[#shadow.loaded]

            if type(ammo_section) ~= "string"
            or ammo_section == ""
            then
                return false, "invalid_ammo", copy_loaded(shadow.loaded)
            end

            stack.pop(shadow.loaded)

            return true, nil, copy_loaded(shadow.loaded), ammo_section
        end

        local function validate_unload_parent(
            magazine,
            expected_parent_server_id,
            requester_netid,
            parent_kind
        )
            local parent = magazine:parent()

            if not parent then
                return false, "parent_missing"
            end

            mags_mp_log(
                "parent resolved requester=%s kind=%s parent=%s",
                tostring(requester_netid),
                tostring(parent_kind),
                tostring(parent:id())
            )

            if parent_kind == "actor" then
                if IsInvbox(parent)
                or (
                    IsStalker(parent)
                    and not parent:alive()
                )
                then
                    return false, "actor_kind_mismatch"
                end

                return true
            end

            if parent_kind == "object" then
                if not is_valid_server_id(expected_parent_server_id) then
                    return false, "parent_server_id_invalid"
                end

                local actual_parent_server_id =
                    GameManager:GetServerIDByLocalID(parent:id())

                if actual_parent_server_id ~= expected_parent_server_id then
                    return false, "object_parent_mismatch"
                end

                local allowed =
                    IsInvbox(parent)
                    or (
                        IsStalker(parent)
                        and not parent:alive()
                    )

                if not allowed then
                    return false, "parent_not_allowed"
                end

                return true
            end

            return false, "parent_kind_invalid"
        end

        magazines.request_unload_operation = function(data)
            if not IIsHost() then
                return
            end

            if type(data) ~= "table" then
                return
            end

            local magazine_server_id = tonumber(data[1])
            local expected_parent_server_id = tonumber(data[2])
            local requester_netid = tonumber(data[3])
            local parent_kind = data[4]
            local request_sequence = tonumber(data[5])
            local expected_round_count = tonumber(data[6])
            local mode = data[7]
            local owner_scope = data[8]
            local session_id = data[9]
            local initial_loaded = data[10]

            mags_mp_log(
                "%s request received mag=%s requester=%s seq=%s expected=%s kind=%s",
                tostring(mode),
                tostring(magazine_server_id),
                tostring(requester_netid),
                tostring(request_sequence),
                tostring(expected_round_count),
                tostring(parent_kind)
            )

            if not is_valid_server_id(magazine_server_id)
            or not requester_netid
            or not request_sequence
            or not expected_round_count
            or (mode ~= "step" and mode ~= "all" and mode ~= "step_remote_actor")
            then
                return
            end

            if parent_kind ~= "actor"
            and parent_kind ~= "object"
            then
                return
            end

            local result_key =
                tostring(requester_netid)
                .. ":"
                .. tostring(session_id or magazine_server_id)

            local previous = host_unload_results[result_key]

            if previous
            and request_sequence <= previous.sequence
            and expected_round_count == previous.expected_count
            then
                if request_sequence == previous.sequence then
                    send_unload_result(
                        requester_netid,
                        magazine_server_id,
                        request_sequence,
                        previous.success,
                        previous.error_code,
                        previous.loaded,
                        previous.mode,
                        previous.ammo_section
                    )
                else
                    send_unload_result(
                        requester_netid,
                        magazine_server_id,
                        request_sequence,
                        false,
                        "stale_sequence",
                        previous.loaded,
                        mode
                    )
                end

                return
            end

            if owner_scope == "remote_actor"
            or mode == "step_remote_actor"
            then
                if not session_id then
                    send_unload_result(
                        requester_netid,
                        magazine_server_id,
                        request_sequence,
                        false,
                        "session_missing",
                        {},
                        mode
                    )
                    return
                end

                local shadow_key = result_key
                local shadow = host_remote_sessions[shadow_key]

                if not shadow then
                    if type(initial_loaded) ~= "table" then
                        send_unload_result(
                            requester_netid,
                            magazine_server_id,
                            request_sequence,
                            false,
                            "shadow_missing",
                            {},
                            mode
                        )
                        return
                    end

                    shadow = {
                        requester_netid = requester_netid,
                        session_id = session_id,
                        loaded = copy_loaded(initial_loaded),
                        last_sequence = 0,
                        cached_results = {},
                        ammo_boxes = {}
                    }

                    host_remote_sessions[shadow_key] = shadow

                    mags_mp_log(
                        "remote session started requester=%s session=%s count=%s",
                        tostring(requester_netid),
                        tostring(session_id),
                        tostring(#shadow.loaded)
                    )
                end

                if not same_netid(shadow.requester_netid, requester_netid) then
                    send_unload_result(
                        requester_netid,
                        magazine_server_id,
                        request_sequence,
                        false,
                        "requester_mismatch",
                        copy_loaded(shadow.loaded),
                        mode
                    )
                    return
                end

                if unload_in_progress[result_key] then
                    send_unload_result(
                        requester_netid,
                        magazine_server_id,
                        request_sequence,
                        false,
                        "in_progress",
                        copy_loaded(shadow.loaded),
                        mode
                    )
                    return
                end

                unload_in_progress[result_key] = true

                local ok, result_success, result_error, result_loaded, result_ammo = pcall(function()
                    return execute_host_remote_unload_step(
                        shadow,
                        expected_round_count
                    )
                end)

                unload_in_progress[result_key] = nil

                local success = result_success
                local error_code = result_error
                local loaded = result_loaded or copy_loaded(shadow.loaded)
                local ammo_section = result_ammo

                if not ok then
                    success = false
                    error_code = "runtime_error:"..tostring(result_success)
                    loaded = copy_loaded(shadow.loaded)
                    ammo_section = nil
                end

                host_unload_results[result_key] = {
                    sequence = request_sequence,
                    success = success and true or false,
                    error_code = error_code or "",
                    loaded = copy_loaded(loaded),
                    mode = mode,
                    expected_count = expected_round_count,
                    ammo_section = ammo_section
                }

                mags_mp_log(
                    "remote shadow committed requester=%s session=%s seq=%s success=%s error=%s ammo=%s remaining=%s",
                    tostring(requester_netid),
                    tostring(session_id),
                    tostring(request_sequence),
                    tostring(success),
                    tostring(error_code),
                    tostring(ammo_section),
                    tostring(#(loaded or {}))
                )

                send_unload_result(
                    requester_netid,
                    magazine_server_id,
                    request_sequence,
                    success,
                    error_code,
                    loaded,
                    mode,
                    ammo_section
                )
                return
            end

            local magazine_local_id =
                GameManager:GetLocalIDByServerID(magazine_server_id)

            local magazine =
                magazine_local_id
                and level.object_by_id(magazine_local_id)

            if not magazine
            or not magazines.is_magazine(magazine)
            then
                send_unload_result(
                    requester_netid,
                    magazine_server_id,
                    request_sequence,
                    false,
                    "magazine_missing",
                    nil,
                    mode
                )
                return
            end

            mags_mp_log(
                "magazine resolved mag=%s local=%s requester=%s seq=%s",
                tostring(magazine_server_id),
                tostring(magazine_local_id),
                tostring(requester_netid),
                tostring(request_sequence)
            )

            local parent_ok, parent_error = validate_unload_parent(
                magazine,
                expected_parent_server_id,
                requester_netid,
                parent_kind
            )

            if not parent_ok then
                send_unload_result(
                    requester_netid,
                    magazine_server_id,
                    request_sequence,
                    false,
                    parent_error,
                    nil,
                    mode
                )
                return
            end

            if unload_in_progress[result_key] then
                send_unload_result(
                    requester_netid,
                    magazine_server_id,
                    request_sequence,
                    false,
                    "in_progress",
                    nil,
                    mode
                )
                return
            end

            unload_in_progress[result_key] = true

            local host_session = host_unload_sessions[result_key] or { ammo_boxes = {} }
            host_unload_sessions[result_key] = host_session

            local ok, result_success, result_error, result_loaded, result_ammo, result_credit = pcall(function()
                if mode == "step" then
                    return execute_host_unload_step(
                        magazine,
                        expected_round_count,
                        host_session
                    )
                end

                return execute_host_unload_all(
                    magazine,
                    expected_round_count
                )
            end)

            unload_in_progress[result_key] = nil

            local success = result_success
            local error_code = result_error
            local loaded = result_loaded
            local ammo_section = result_ammo

            if not ok then
                success = false
                error_code = "runtime_error:"..tostring(result_success)
                loaded = get_authoritative_loaded_safe(magazine)
                ammo_section = nil
            end

            mags_mp_log(
                "%s host committed mag=%s requester=%s seq=%s success=%s error=%s ammo=%s remaining=%s",
                tostring(mode),
                tostring(magazine_server_id),
                tostring(requester_netid),
                tostring(request_sequence),
                tostring(success),
                tostring(error_code),
                tostring(ammo_section),
                tostring(#(loaded or {}))
            )

            host_unload_results[result_key] = {
                sequence = request_sequence,
                success = success and true or false,
                error_code = error_code or "",
                loaded = copy_loaded(loaded),
                mode = mode,
                expected_count = expected_round_count,
                ammo_section = ammo_section
            }

            send_unload_result(
                requester_netid,
                magazine_server_id,
                request_sequence,
                success,
                error_code,
                loaded,
                mode,
                ammo_section
            )
        end

        local function send_unload_request(obj, request_sequence, expected_round_count, mode)
            if not obj
            or not obj:parent()
            or not magazines.is_magazine(obj)
            then
                return false
            end

            local parent = obj:parent()
            local magazine_server_id = GameManager:GetServerIDByLocalID(obj:id())
            local requester_netid = GameManager:GetMySNETID()
            local parent_kind = get_unload_parent_kind(parent)
            local owner_scope

            if IIsHost()
            and db.actor
            and parent:id() == db.actor:id()
            then
                owner_scope = "host_actor"
            elseif not IIsHost()
            and db.actor
            and parent:id() == db.actor:id()
            then
                owner_scope = "remote_actor"
            else
                owner_scope = "object"
            end

            if owner_scope == "remote_actor"
            and mode == "step"
            then
                mode = "step_remote_actor"
            end

            if not is_valid_server_id(magazine_server_id)
            or not requester_netid
            then
                return false
            end

            local parent_server_id = 0

            if parent_kind == "object" then
                parent_server_id = GameManager:GetServerIDByLocalID(parent:id())

                if not is_valid_server_id(parent_server_id) then
                    return false
                end
            end

            local session = local_unload_sessions[magazine_server_id]

            local payload = {
                magazine_server_id,
                parent_server_id,
                requester_netid,
                parent_kind,
                request_sequence,
                expected_round_count,
                mode,
                owner_scope,
                session and session.session_id,
                session and session.initial_loaded
            }

            if IIsHost() then
                magazines.request_unload_operation(payload)
            else
                GameManager:OnICustomScriptAction(
                    "magazines",
                    "request_unload_operation",
                    serialize_table_simple(payload),
                    true
                )
            end

            mags_mp_log(
                "%s request sent mag=%s requester=%s seq=%s expected=%s kind=%s",
                tostring(mode),
                tostring(magazine_server_id),
                tostring(requester_netid),
                tostring(request_sequence),
                tostring(expected_round_count),
                tostring(parent_kind)
            )

            return true
        end

        local function remove_unload_ack_timeout(magazine_server_id)
            local session = local_unload_sessions[magazine_server_id]

            if session then
                session.awaiting_ack = false
            end
        end

        local function start_unload_ack_timeout(magazine_server_id, sequence)
            local session = local_unload_sessions[magazine_server_id]

            if not session then
                return
            end

            CreateTimeEvent(
                "mag_redux",
                session.timeout_event_id.."_"..tostring(sequence),
                5,
                function()
                    local active = local_unload_sessions[magazine_server_id]

                    if active
                    and active.awaiting_ack
                    and active.sequence == sequence
                    then
                        mags_mp_log(
                            "ACK timeout mag=%s requester=%s seq=%s expected=%s",
                            tostring(magazine_server_id),
                            tostring(active.requester_netid),
                            tostring(sequence),
                            tostring(active.expected_count)
                        )
                        cancel_local_unload(
                            magazine_server_id,
                            "host timeout"
                        )
                    end

                    return true
                end
            )
        end

        local function schedule_next_unload_step(magazine_server_id)
            local session = local_unload_sessions[magazine_server_id]

            if not session
            or session.awaiting_ack
            then
                return
            end

            local local_id = GameManager:GetLocalIDByServerID(magazine_server_id)
            local magazine = local_id and level.object_by_id(local_id)

            if not magazine then
                cancel_local_unload(
                    magazine_server_id,
                    "magazine missing"
                )
                return
            end

            local delay = magazines.get_mag_time(magazine:section(), true)
            local request_sequence = session.sequence + 1
            local step_event_id =
                session.event_id
                .. "_"
                .. tostring(request_sequence)

            mags_mp_log(
                "next step scheduled mag=%s requester=%s seq=%s expected=%s delay=%s",
                tostring(magazine_server_id),
                tostring(session.requester_netid),
                tostring(request_sequence),
                tostring(session.expected_count),
                tostring(delay)
            )

            CreateTimeEvent(
                "mag_redux",
                step_event_id,
                delay,
                function()
                    local ok, finished = pcall(function()
                        local active = local_unload_sessions[magazine_server_id]

                        if not active then
                            return true
                        end

                        mags_mp_log(
                            "step timer fired mag=%s requester=%s seq=%s expected=%s",
                            tostring(magazine_server_id),
                            tostring(active.requester_netid),
                            tostring(active.sequence + 1),
                            tostring(active.expected_count)
                        )

                        if ui_inventory.GUI
                        and not ui_inventory.GUI:IsShown()
                        then
                            cancel_local_unload(
                                magazine_server_id,
                                "UI closed"
                            )
                            return true
                        end

                        local current_local_id =
                            GameManager:GetLocalIDByServerID(magazine_server_id)
                        local current_magazine =
                            current_local_id
                            and level.object_by_id(current_local_id)

                        if not current_magazine then
                            cancel_local_unload(
                                magazine_server_id,
                                "magazine missing"
                            )
                            return true
                        end

                        local parent = current_magazine:parent()

                        if not parent
                        or parent:id() ~= active.parent_local_id
                        then
                            cancel_local_unload(
                                magazine_server_id,
                                "parent changed"
                            )
                            return true
                        end

                        local current_data =
                            magazines.get_mag_data(current_magazine:id())

                        if not current_data
                        or type(current_data.loaded) ~= "table"
                        or #current_data.loaded ~= active.expected_count
                        then
                            cancel_local_unload(
                                magazine_server_id,
                                "local state changed"
                            )
                            return true
                        end

                        active.sequence = active.sequence + 1
                        active.awaiting_ack = true

                        local sent = send_unload_request(
                            current_magazine,
                            active.sequence,
                            active.expected_count,
                            "step"
                        )

                        if not sent then
                            cancel_local_unload(
                                magazine_server_id,
                                "request failed"
                            )
                            return true
                        end

                        start_unload_ack_timeout(
                            magazine_server_id,
                            active.sequence
                        )

                        return true
                    end)

                    if not ok then
                        cancel_local_unload(
                            magazine_server_id,
                            "runtime error: "..tostring(finished)
                        )
                        return true
                    end

                    return finished
                end
            )
        end

        local function local_credit_one_round(session, ammo_section)
            if not session
            or type(ammo_section) ~= "string"
            or ammo_section == ""
            or not db.actor
            then
                return false
            end

            session.ammo_boxes = session.ammo_boxes or {}

            local box_size = SYS_GetParam(2, ammo_section, "box_size", 1)
            box_size = tonumber(box_size) or 1
            if box_size < 1 then box_size = 1 end

            local credit = session.ammo_boxes[ammo_section]
            local ammo_obj

            if credit and credit.local_id then
                ammo_obj = level.object_by_id(credit.local_id)
            end

            if ammo_obj
            and ammo_obj:parent()
            and ammo_obj:parent():id() == db.actor:id()
            and ammo_obj.ammo_get_count
            and ammo_obj.ammo_set_count
            and ammo_obj:ammo_get_count() < box_size
            then
                local new_count = ammo_obj:ammo_get_count() + 1
                ammo_obj:ammo_set_count(new_count)
                credit.count = new_count
                return true, new_count, false
            end

            local created = ORIGINAL_CREATE_AMMO and ORIGINAL_CREATE_AMMO(
                ammo_section,
                db.actor:position(),
                db.actor:level_vertex_id(),
                db.actor:game_vertex_id(),
                db.actor:id(),
                1
            )

            if type(created) ~= "table" then
                return false
            end

            local created_id
            for _, obj in pairs(created) do
                created_id = get_created_object_id(obj)
                if created_id then break end
            end

            if not created_id then
                return false
            end

            session.ammo_boxes[ammo_section] = {
                local_id = created_id,
                count = 1,
                box_size = box_size
            }

            return true, 1, true
        end

        magazines.unload_operation_result = function(data)
            if type(data) ~= "table" then
                return
            end

            local target_netid = data[1]

            if not same_netid(
                target_netid,
                GameManager:GetMySNETID()
            ) then
                return
            end

            local magazine_server_id = tonumber(data[2])
            local sequence = tonumber(data[3])
            local success = data[4] and true or false
            local error_code = tostring(data[5] or "")
            local loaded = data[6] or {}
            local mode = data[7]
            local ammo_section = data[8]

            mags_mp_log(
                "ACK received target=%s mag=%s seq=%s mode=%s success=%s error=%s remaining=%s",
                tostring(target_netid),
                tostring(magazine_server_id),
                tostring(sequence),
                tostring(mode),
                tostring(success),
                tostring(error_code),
                tostring(#loaded)
            )

            local session = local_unload_sessions[magazine_server_id]

            if mode == "step"
            or mode == "step_remote_actor"
            then
                if not session
                or sequence ~= session.sequence
                then
                    return
                end

                session.awaiting_ack = false
                remove_unload_ack_timeout(magazine_server_id)
            end

            if not success then
                if type(loaded) == "table" then
                    apply_authoritative_mag_state(
                        magazine_server_id,
                        loaded
                    )
                end

                cancel_local_unload(
                    magazine_server_id,
                    error_code
                )
                return
            end

            local function after_state_applied()
                if mode == "step_remote_actor" then
                    local active = local_unload_sessions[magazine_server_id]
                    local credited, count, created_new = local_credit_one_round(
                        active,
                        ammo_section
                    )

                    if not credited then
                        cancel_local_unload(
                            magazine_server_id,
                            "ammo_credit_failed"
                        )
                        return
                    end

                    mags_mp_log(
                        "client ammo box %s mag=%s seq=%s ammo=%s count=%s",
                        created_new and "created" or "incremented",
                        tostring(magazine_server_id),
                        tostring(sequence),
                        tostring(ammo_section),
                        tostring(count)
                    )
                end

                if magazines.inventory_refresh then
                    pcall(magazines.inventory_refresh, 2)
                end

                pcall(magazines.timed_refresh)

                play_unload_step_sound(magazine_server_id)

                mags_mp_log(
                    "step sound played mag=%s seq=%s mode=%s remaining=%s",
                    tostring(magazine_server_id),
                    tostring(sequence),
                    tostring(mode),
                    tostring(#loaded)
                )

                CreateTimeEvent(
                    "mag_redux",
                    "refresh_after_unload_"..tostring(magazine_server_id).."_"..tostring(sequence),
                    0.25,
                    function()
                        magazines.timed_refresh()
                        return true
                    end
                )

                if mode ~= "step"
                and mode ~= "step_remote_actor"
                then
                    return
                end

                local active = local_unload_sessions[magazine_server_id]

                if not active then
                    return
                end

                active.expected_count = #loaded

                if active.expected_count == 0 then
                    mags_mp_log(
                        "session completed mag=%s seq=%s",
                        tostring(magazine_server_id),
                        tostring(sequence)
                    )
                    finish_local_unload(magazine_server_id)
                    return
                end

                if ui_inventory.GUI
                and not ui_inventory.GUI:IsShown()
                then
                    finish_local_unload(magazine_server_id)
                    return
                end

                mags_mp_log(
                    "next step after ACK mag=%s seq=%s expected=%s",
                    tostring(magazine_server_id),
                    tostring(sequence),
                    tostring(active.expected_count)
                )

                schedule_next_unload_step(magazine_server_id)
            end

            local applied = apply_authoritative_mag_state(
                magazine_server_id,
                loaded,
                nil,
                after_state_applied
            )

            if applied == false then
                cancel_local_unload(
                    magazine_server_id,
                    "state_apply_failed"
                )
            end
        end

        local function start_slow_multiplayer_unload(obj)
            if not obj
            or not obj:parent()
            or not magazines.is_magazine(obj)
            then
                return false
            end

            local mag_data = magazines.get_mag_data(obj:id())

            if not mag_data
            or type(mag_data.loaded) ~= "table"
            or #mag_data.loaded == 0
            then
                return false
            end

            local magazine_server_id = GameManager:GetServerIDByLocalID(obj:id())

            if type(magazine_server_id) ~= "number" then
                return false
            end

            if local_unload_sessions[magazine_server_id] then
                return false
            end

            local parent = obj:parent()

            local session = {
                session_id = tostring(GameManager:GetMySNETID())
                    .. ":"
                    .. tostring(time_global())
                    .. ":"
                    .. tostring(obj:id()),
                local_magazine_id = obj:id(),
                magazine_section = obj:section(),
                initial_loaded = copy_loaded(mag_data.loaded),
                expected_loaded = copy_loaded(mag_data.loaded),
                sequence = time_global(),
                awaiting_ack = false,
                expected_count = #mag_data.loaded,
                parent_local_id = parent:id(),
                parent_kind = get_unload_parent_kind(parent),
                requester_netid = GameManager:GetMySNETID(),
                ammo_boxes = {},
                event_id = "mags_unload_step_"..tostring(magazine_server_id),
                timeout_event_id = "mags_unload_timeout_"..tostring(magazine_server_id)
            }

            local_unload_sessions[magazine_server_id] = session

            mags_mp_log(
                "slow session started mag=%s requester=%s expected=%s kind=%s parent=%s",
                tostring(magazine_server_id),
                tostring(session.requester_netid),
                tostring(session.expected_count),
                tostring(session.parent_kind),
                tostring(session.parent_local_id)
            )

            schedule_next_unload_step(magazine_server_id)

            return true
        end

        magazines.func_unload_ammo = function(obj)
            if not (obj and obj:parent() and magazines.is_magazine(obj)) then
                return
            end

            if not mags_mp_active() then
                return OLDUNJECMAGS and OLDUNJECMAGS(obj)
            end

            local parent = obj:parent()

            local fast_unload =
                IsInvbox(parent)
                or not magazines_mcm
                or magazines_mcm.get_config(
                    "unload_behavior"
                ) == 1

            if fast_unload then
                local mag_data = magazines.get_mag_data(obj:id())
                local expected_count =
                    mag_data
                    and type(mag_data.loaded) == "table"
                    and #mag_data.loaded
                    or 0

                return send_unload_request(
                    obj,
                    time_global(),
                    expected_count,
                    "all"
                )
            end

            return start_slow_multiplayer_unload(obj)
        end
        -- Load ammo functos
        magazines.fast_load_magazine = function (obj, ammo_obj, load_one)
            if not (obj and obj:parent() and ammo_obj and ammo_obj:parent()) then return end
            local mag_data = magazines.get_mag_data(obj:id())
            if not mag_data then return end
            local parent = ammo_obj:parent()
            local mag_parent = obj:parent()
            local ammo_sec = ammo_obj:section()
            local capacity = SYS_GetParam(2, obj:section(), "max_mag_size")
            local ammo_to_load = capacity - #mag_data.loaded
            local flagslow = not IsInvbox(mag_parent) or not magazines_mcm or magazines_mcm.get_config("unload_behavior") == 1
            local flaglocal = mag_parent:id() == db.actor:id()
            local function itr_box(_, item)
                if item:section() == ammo_sec and ammo_to_load > 0 then
                    if ui_inventory.GUI and not ui_inventory.GUI:IsShown() then
                        printf("== Player interrupt that unload")
                        return true
                    end
                    local available = item:ammo_get_count()
                    local to_take = math.min(available, ammo_to_load)
                    ammo_to_load = ammo_to_load - to_take
                    for _ = 1, to_take do
                        stack.push(mag_data.loaded, ammo_sec)
                    end
                    -- Check who parent and determ sync that or no
                    if to_take == available then
                        if flaglocal then
                            alife_release(item)
                        else
                            alife_release_client(item)
                        end
                    elseif flaglocal then
                        item:ammo_set_count(available - to_take)
                    else
                        local num = available - to_take
                        item:ammo_set_count(num)
                        local payload = { GameManager:GetServerIDByLocalID(item:id()), num, true }
                        GameManager:OnICustomScriptAction("magazines", "remote_set_mag_or_ammo", serialize_table_simple(payload), false)
                    end
                    -- Save data and sync
                    magazines.set_mag_data(obj:id(), mag_data)
                    magazines.timed_refresh()
                    -- Play sound
                    xr_sound.set_sound_play(db.actor:id(), "reload_shell")
                    -- Sync mag data
                    if not flaglocal then
                        local payload = { GameManager:GetServerIDByLocalID(obj:id()), { #mag_data.loaded,  mag_data.loaded[1] } }
                        GameManager:OnICustomScriptAction("magazines", "remote_set_mag_or_ammo", serialize_table_simple(payload), false)
                    end
                    return flagslow
                end
            end
            -- Depends on flag doing iterating and filling
            if flagslow then
                local delay = magazines.get_mag_time(obj:section(), true)
                CreateTimeEvent("mag_redux", "load_mag_remote_"..obj:section(), delay, function (magazine)
                    if IsInvbox(parent) then
                        parent:iterate_inventory_box(itr_box)
                    else
                        parent:iterate_inventory(itr_box)
                    end
                end)
            elseif IsInvbox(parent) then
                parent:iterate_inventory_box(itr_box)
            else
                parent:iterate_inventory(itr_box)
            end
        end
    end
    -- ANIMOR and WERASIK2AA...
    if ui_pda_taskboard_tab and pda_taskboard and z_taskboard_overrides then
        pda_taskboard.get_details = function(task_info)
            if IIsHost() then return OLDTBDETALS(task_info) end
            return task_info or {}
        end
        pda_taskboard.remote_request_improved_taskboard = function(table_data, onlyreturn)
            local netid = table_data.netid
            local srv_ids = table_data.srv_ids
            local response_data = {}
            pda_taskboard.refresh_tasks()
            for _, srv_id in ipairs(srv_ids) do
                local npc = level.object_by_id(srv_id)
                if npc then
                    ui_pda_taskboard_tab.currently_processed_npc_id = srv_id
                    local backend_data = MPMain_QuestPatches_STOGETHER.get_busied_npcs()
                    backend_data[65536] = { id = npc:id(), busy = true, netid = netid }
                    axr_task_manager.generate_available_tasks(npc, string.find(npc:section(), "sim_", 1, true))
                    local tasks = axr_task_manager.available_tasks[srv_id] or {}
                    for _, task_id in ipairs(tasks) do
                        z_taskboard_overrides.StartOverride()
                        pda_taskboard.prepare_task({ task_id = task_id, npc_id = srv_id })
                        z_taskboard_overrides.StopOverride()
                        MPMain_QuestPatches_STOGETHER.sync_task_variables(task_id, netid)
                        --Begin job collector
                        local task_effect = pda_taskboard.get_task_effect(task_id)
                        local details = pda_taskboard.get_details({ task_id = task_id, has_details = false })
                        if not response_data[task_effect] then response_data[task_effect] = {} end
                        response_data[task_effect][#response_data[task_effect]+1] = {
                            npc_id = srv_id,
                            task_id = task_id,
                            task_details = details and details.task_details or nil,
                            task_icon = details and details.task_icon or task_manager.task_ini:r_string_ex(task_id, "icon") or "ui_icon_equipment_unknown",
                            task_fetch = load_var(db.actor, task_id .. "_fetch")
                        }
                    end
                    backend_data[65536] = nil
                    ui_pda_taskboard_tab.currently_processed_npc_id = nil
                end
            end
            if onlyreturn then return response_data end
            GameManager:OnICustomScriptAction("pda_taskboard", "remote_receive_improved_taskboard", serialize_table_simple(response_data), false, netid)
        end
        pda_taskboard.remote_receive_improved_taskboard = function(table_data)
            local backend_data = pda_taskboard.get_data()
            empty_table(backend_data)
            -- Convert to normal ids and finish it
            for k, tasks in pairs(table_data) do
                backend_data[k] = {}
                for _, t in ipairs(tasks) do
                    local pprope = MPMain_QuestPatches_STOGETHER.client_draw_postpone_locally(t.task_id)
                    t.npc_id = GameManager:GetLocalIDByServerID(t.npc_id)
                    t.task_description = pda_taskboard.get_long_task_description({ task_id = t.task_id })
                    t.task_title = game.translate_string(task_manager.task_ini:r_string_ex(t.task_id, "title") or "")
                    t.task_details = t.task_details or pprope and pprope[2] or ""
                    if t.task_fetch then
                        t.task_title = t.task_title:gsub("%%s", ui_item.get_sec_name(t.task_fetch))
                    else -- Freq parse to string key
                        local data = load_var(db.actor, t.task_id)
                        if type(data) == "table" and data.freq then
                            t.task_title = utils_data.parse_string_keys(t.task_title, { ["freq"] = data.freq })
                        end
                    end
                    t.has_details = true
                    backend_data[k][#backend_data[k]+1] = t
                end
            end
            local ui = ui_pda_taskboard_tab.get_ui()
            if ui and ui:IsShown() then
                ui:DrawCategoryList()
            end
        end
        function ui_pda_taskboard_tab.pda_taskboard_tab:OnBtnRefreshClicked()
            if IIsHost() then
                self.task_list:RemoveAll()
                pda_taskboard.refresh_tasks()
                self:DrawCategoryList()
                return
            end
            self.task_list:RemoveAll()
            self.category_list:RemoveAll()
            local srv_ids = {}
            local npc_list = pda_taskboard.get_nearby_npcs()
            for _, npc in ipairs(npc_list) do
                if not IsActor(npc) then
                    srv_ids[#srv_ids+1] = GameManager:GetServerIDByLocalID(npc:id())
                end
            end
            if #srv_ids > 0 then
                local payload = { srv_ids = srv_ids, netid = GameManager:GetMySNETID() }
                GameManager:OnICustomScriptAction("pda_taskboard", "remote_request_improved_taskboard", serialize_table_simple(payload), true)
                actor_menu.set_msg(1, game.translate_string("st_pda_accessing_network"), 3)
            end
        end
    elseif ui_pda_taskboard_tab and z_taskboard_overrides then
        if not ui_pda_taskboard_tab.get_task_effect then
            ui_pda_taskboard_tab.get_task_effect = function (task_id)
                local raw_task_effect_descr = task_manager.task_ini:r_string_ex(task_id, "on_job_descr")
                local raw_task_effect_fetch = task_manager.task_ini:r_string_ex(task_id, "fetch_func")
                local str = raw_task_effect_descr or raw_task_effect_fetch or ""
			    local task_effect = string.gmatch(str, "=(.*)%(")() or "rest"
                return ui_pda_taskboard_tab.normalize_task_effect(task_effect)
            end
        end
        ui_pda_taskboard_tab.remote_request_taskboard_data = function(table_data, onlyreturn)
            local netid = table_data.netid
            local response_data = {}
            for _, srv_id in ipairs(table_data.srv_ids) do
                local npc = level.object_by_id(srv_id)
                if npc then
                    ui_pda_taskboard_tab.currently_processed_npc_id = srv_id
                    local backend_data = MPMain_QuestPatches_STOGETHER.get_busied_npcs()
                    backend_data[65536] = { id = npc:id(), busy = true, netid = netid }
                    axr_task_manager.generate_available_tasks(npc, string.find(npc:section(), "sim_", 1, true) ~= nil)
                    z_taskboard_overrides.clear_tasks_info()
                    local tasks = axr_task_manager.available_tasks[srv_id] or {}
                    for _, task_id in ipairs(tasks) do
                        ui_pda_taskboard_tab.prepare_task({ task_id = task_id, npc_id = srv_id })
                        MPMain_QuestPatches_STOGETHER.sync_task_variables(task_id, netid)
                        -- Begin job collector
                        local info = z_taskboard_overrides.tasks_info[1] or {}
                        local task_effect = ui_pda_taskboard_tab.get_task_effect(task_id)
                        if not response_data[task_effect] then response_data[task_effect] = {} end
                        response_data[task_effect][#response_data[task_effect]+1] = {
                            npc_id = srv_id,
                            task_id = task_id,
                            task_details = info and info.task_details,
                            task_icon = info and info.task_icon or task_manager.task_ini:r_string_ex(task_id, "icon") or "ui_icon_equipment_unknown",
                            task_fetch = load_var(db.actor, task_id .. "_fetch")
                        }
                    end
                    backend_data[65536] = nil
                    ui_pda_taskboard_tab.currently_processed_npc_id = nil
                end
            end
            if onlyreturn then return response_data end
            GameManager:OnICustomScriptAction("ui_pda_taskboard_tab", "remote_receive_taskboard_data", serialize_table_simple(response_data), false, netid)
        end
        ui_pda_taskboard_tab.global_prepared_tasks_data = {}
        ui_pda_taskboard_tab.remote_receive_taskboard_data = function(table_data)
            local backend_data = ui_pda_taskboard_tab.global_prepared_tasks_data
            empty_table(backend_data)
            -- Convert to normal ids and finish it
            for k, tasks in pairs(table_data) do
                backend_data[k] = {}
                for _, t in ipairs(tasks) do
                    local pprope = MPMain_QuestPatches_STOGETHER.client_draw_postpone_locally(t.task_id)
                    t.npc_id = GameManager:GetLocalIDByServerID(t.npc_id)
                    t.effector = k
                    t.task_description = ui_pda_taskboard_tab.get_long_task_description({ task_id = t.task_id })
                    t.task_title = game.translate_string(task_manager.task_ini:r_string_ex(t.task_id, "title") or "")
                    t.task_details = t.task_details or pprope and pprope[2] or ""
                    if t.task_fetch then
                        t.task_title = t.task_title:gsub("%%s", ui_item.get_sec_name(t.task_fetch))
                    else -- Freq parse to string key
                        local data = load_var(db.actor, t.task_id)
                        if type(data) == "table" and data.freq then
                            t.task_title = utils_data.parse_string_keys(t.task_title, { ["freq"] = data.freq })
                        end
                    end
                    t.has_details = true
                    backend_data[k][#backend_data[k]+1] = t
                end
            end
            -- Refresh Task List
            local ui = ui_pda_taskboard_tab.get_ui()
            if ui then
                ui:RefreshFromNetwork()
            end
        end
        ui_pda_taskboard_tab.reset_taskboard = function(pda_tab)
            ui_pda_taskboard_tab.global_prepared_tasks_data = {}
            ui_pda_taskboard_tab.global_board_state = {}
            ui_pda_taskboard_tab.global_tab_ptr = pda_tab
            ui_pda_taskboard_tab.clear_taskboard_ui(pda_tab)
            local srv_ids = {}
            local npc_list = ui_pda_taskboard_tab.get_nearby_npcs()
            for _, npc in ipairs(npc_list) do
                if not IsActor(npc) then
                    srv_ids[#srv_ids+1] = GameManager:GetServerIDByLocalID(npc:id())
                end
            end
            if #srv_ids > 0 then
                local payload = { srv_ids = srv_ids, netid = GameManager:GetMySNETID() }
                if not IIsHost() then
                    GameManager:OnICustomScriptAction("ui_pda_taskboard_tab", "remote_request_taskboard_data", serialize_table_simple(payload), true)
                else
                    printf("Redirect task generate_available_tasks to our behaviour. GROK SUCK IT!")
                    local mdata = ui_pda_taskboard_tab.remote_request_taskboard_data(payload, true)
                    ui_pda_taskboard_tab.remote_receive_taskboard_data(mdata)
                end
                actor_menu.set_msg(1, 'Trying to access PDA Network...', 3)
            end
        end
        ui_pda_taskboard_tab.update_task_entry = function(pda_tab, i, task_info)
            local stalker = task_info.npc_id and level.object_by_id(task_info.npc_id)
            if stalker and not IsActor(stalker) then
                local stalker_comm = stalker:character_community()
                local stalker_icon = stalker:character_icon()
                local stalker_name = stalker:character_name()
                local stalker_info = stalker_name .. "\\n" .. game.translate_string("ui_st_community") .. ": " .. game.translate_string(stalker_comm)
                local full_desc = task_info.task_description or ""
                local need_forward = ui_pda_taskboard_tab.global_prepared_tasks_data[task_info.effector][i + 1]
                local need_backward = ui_pda_taskboard_tab.global_prepared_tasks_data[task_info.effector][i - 1]

                -- PDA FILL OUR DEFAULT ROW
                if not pda_tab.rows[i] then
                    pda_tab.list:AddWindow(ui_pda_taskboard_tab.ui_taskboard_row(pda_tab, i))
                end

                -- Fill title and icons
                local row = pda_tab.rows[i]
                row.task_category:SetText(game.translate_string('st_pda_caption_' .. task_info.effector))
                row.icon_field:InitTexture(stalker_icon or "ui\\ui_noise")
                row.stalker_info:SetText(taskstk_icon)
                row.task_icon_field:InitTexture(task_info.task_icon)

                -- Fill descriptions
                local pprope = MPMain_QuestPatches_STOGETHER.client_draw_postpone_locally(task_info.task_id)
                row.task_details_field:SetText(pprope and pprope[2] or "---")
                row.task_full_description_field:SetText(full_desc)
                row.task_next_btn:Show(need_forward)
                if row.task_previous_btn then
                    row.task_previous_btn:Show(need_backward)
                end
                -- Add Accept button on new version
                if ui_pda_taskboard_tab.manage_accept_button then
                    ui_pda_taskboard_tab.manage_accept_button(stalker, row)
                    return
                end
                -- Old version add button or not
                if dialogs.has_tasks_by_npc(stalker) then
                    row.task_next_btn:Show(true)
                    row.task_accept_btn:Show(false)
                else
                    row.task_next_btn:Show(false)
                    row.task_accept_btn:Show(true)
                end
            end
        end
        ui_pda_taskboard_tab.global_board_state = {}
        function ui_pda_taskboard_tab.pda_taskboard_tab:RefreshFromNetwork()
            ui_pda_taskboard_tab.clear_taskboard_ui(self)
            for _, tasks in pairs(ui_pda_taskboard_tab.global_prepared_tasks_data) do
                local row_index = #ui_pda_taskboard_tab.global_board_state + 1
                ui_pda_taskboard_tab.global_board_state[row_index] = { pos = 1, tasks = {} }
                for _, t in ipairs(tasks) do
                    ui_pda_taskboard_tab.update_task_entry(ui_pda_taskboard_tab.global_tab_ptr, row_index, t)
                    ui_pda_taskboard_tab.global_board_state[row_index].tasks[#ui_pda_taskboard_tab.global_board_state[row_index].tasks+1] = t
                end
            end
            a_taskboard_utils.adjust_rows(self)
        end
        ui_pda_taskboard_tab.next_task_in_category = function (pda_tab, row_index)
            local entry_info = ui_pda_taskboard_tab.global_board_state[row_index]
            local next_task = entry_info.tasks[entry_info.pos + 1]
            if not next_task then return end
            local stalker = level.object_by_id(next_task.npc_id)
            if stalker then
                entry_info.pos = entry_info.pos + 1
                ui_pda_taskboard_tab.update_task_entry(pda_tab, row_index, next_task)
                a_taskboard_utils.adjust_rows(pda_tab)
            end
        end
        ui_pda_taskboard_tab.previous_task_in_category = function (pda_tab, row_index)
            local entry_info = ui_pda_taskboard_tab.global_board_state[row_index]
            local next_task = entry_info.tasks[entry_info.pos - 1]
            if not next_task then return end
            local stalker = level.object_by_id(next_task.npc_id)
            if stalker then
                entry_info.pos = entry_info.pos - 1
                ui_pda_taskboard_tab.update_task_entry(pda_tab, row_index, next_task)
                a_taskboard_utils.adjust_rows(pda_tab)
            end
        end
        ui_pda_taskboard_tab.accept_task = function(pda_tab, row_index)
            local entry_info = ui_pda_taskboard_tab.global_board_state[row_index]
            local curra_task = entry_info.tasks[entry_info.pos]
            if not curra_task then return end
            task_manager.get_task_manager():give_task(curra_task.task_id, curra_task.npc_id)
            table.remove(entry_info.tasks, entry_info.pos)
            if #entry_info.tasks > 0 then
                table.sort(entry_info)
                entry_info.pos = 1
                ui_pda_taskboard_tab.update_task_entry(pda_tab, row_index, entry_info.tasks[1])
            else
                ui_pda_taskboard_tab.reset_taskboard(pda_tab)
            end
        end
    end
    if bind_workshop_furniture then
        function bind_workshop_furniture.hf_workshop_wrapper:net_spawn(se_abstract)
            if not object_binder.net_spawn(self, se_abstract) then
                return false
            end
            if IIsHost() then return end
            local srv_id = GameManager:GetServerIDByLocalID(self.object:id())
            GameManager:OnICustomScriptAction("ui_furniture_workshop", "GetStash", tostring(srv_id) .. "," .. tostring(GameManager:GetMySNETID()), true)
        end
    end
    if ui_furniture_workshop then
        ui_furniture_workshop.GiveStashItemsToActor = function(workshop_id, stash_id_old)
            -- Client waiting for stash
            local stash_id = IIsHost() and stash_id_old or ui_furniture_workshop.GetStash(workshop_id)
            if not stash_id then return false end
            local box = stash_id and level.object_by_id(stash_id)
            if not box or not IsInvbox(box) then return false end
            if not GameManager:IsStashFirstFilled(stash_id) then
                GameManager:OnIStashOpen(stash_id, false)
                return false
            end
            return OLDTAKEALLW(workshop_id, stash_id) or true
        end
        ui_furniture_workshop.SyncStash = function (tblb)
            local m_data = alife_storage_manager.get_state()
            if not m_data then return end
            if not m_data.workshop_stashes then m_data.workshop_stashes = {} end
            for k,v in pairs(tblb) do
                m_data.workshop_stashes[GameManager:GetLocalIDByServerID(k)] = GameManager:GetLocalIDByServerID(v)
            end
        end
        ui_furniture_workshop.GetStash = function(id, netid)
            local m_data = alife_storage_manager.get_state()
            if not m_data then return end
            if not m_data.workshop_stashes then m_data.workshop_stashes = {} end
            local se_id = m_data.workshop_stashes and m_data.workshop_stashes[id]
            local se_inv_box = se_id and alife_object(se_id)
            if not se_inv_box or not IsInvbox(se_inv_box) then
                -- JUST IF REALLY NOT EXIST
                if not IIsHost() then
                    local srv_id = GameManager:GetServerIDByLocalID(id)
                    GameManager:OnICustomScriptAction("ui_furniture_workshop", "GetStash", tostring(srv_id) .. "," .. tostring(GameManager:GetMySNETID()), true)
                    return
                end
                local obj = level.object_by_id(id)
                if not obj then return end
                local pos = obj:position()
                pos.y = pos.y - 50
                se_inv_box = alife_create("workshop_stash", pos, obj:level_vertex_id(), obj:game_vertex_id())
                if se_inv_box then
                    -- force strictly online (not sure this is needed)
                    alife():set_switch_online(se_inv_box.id, true)
                    alife():set_switch_offline(se_inv_box.id, false)
                    -- Save container
                    m_data.workshop_stashes[id] = se_inv_box.id
                end
            end
            if netid then GameManager:OnICustomScriptAction("ui_furniture_workshop", "SyncStash", serialize_table_simple(m_data.workshop_stashes), false, netid) end
            return se_inv_box and se_inv_box.id or nil
        end
        function ui_furniture_workshop.UIFurnitureWorkshop:AccessStash()
            local stash_id = ui_furniture_workshop.GetStash(self.obj_id)
            if not stash_id then return false end
            CreateTimeEvent("hf_workshop", "wait_stash_"..stash_id, 0.1, function ()
                local box = stash_id and level.object_by_id(stash_id)
                if not box or not IsInvbox(box) then return false end
                if not GameManager:IsStashFirstFilled(stash_id) then
                    GameManager:OnIStashOpen(stash_id, false)
                    return false
                end
                hide_hud_inventory()
                box:use(db.actor)
                return true
            end)
            self:Close()
            return true
        end
        function ui_furniture_workshop.UIFurnitureWorkshop:UseWorkshop()
            if IIsHost() then
                ui_furniture_workshop.UseWorkshop(self.obj_id)
                return true
            end
            local stash_id = ui_furniture_workshop.GetStash(self.obj_id)
            if not stash_id then return false end
            CreateTimeEvent("hf_workshop", "wait_stash_"..stash_id, 0.1, function ()
                local box = stash_id and level.object_by_id(stash_id)
                if not box or not IsInvbox(box) then return false end
                if not GameManager:IsStashFirstFilled(stash_id) then
                    GameManager:OnIStashOpen(stash_id, false)
                    return false
                end
                ui_furniture_workshop.UseWorkshop(self.obj_id)
                return true
            end)
            self:Close()
            return true
        end
    end
