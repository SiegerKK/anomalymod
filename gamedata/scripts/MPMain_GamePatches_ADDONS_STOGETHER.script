    if raid_save_manager then raid_save_manager.allow_save = not level.present() or level.name() == "fake_start" end
    if raid_tasks_scout and raid_tasks_scout_dunge and raid_task_rf_scout_and_delivery_out then
        raid_tasks_scout.remote_scout_point = function (tabled)
            local task_id = tabled[1]
            local smart_id = GameManager:GetLocalIDByServerID(tabled[2])

            -- Sync scouted points for save in list
            local dunge_cur = raid_tasks_dungeons.raid_dunge_active_tasks and raid_tasks_dungeons.raid_dunge_active_tasks[task_id]
            if dunge_cur then
                if dunge_cur.points[smart_id] then
                    dunge_cur.points[smart_id] = "scouted"
				    dunge_cur.scouted = dunge_cur.scouted + 1
                end
            end

            -- Another scout task if something happens it's fallback here too.
            local scout_cur = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if scout_cur then
                if scout_cur.smarts_t[smart_id] then
                    scout_cur.smarts_t[smart_id] = "scouted"
				    scout_cur.scouted = scout_cur.scouted + 1
                end
            end

            if not (scout_cur and scout_cur.smarts_t[smart_id] or dunge_cur and dunge_cur.points[smart_id]) then
                printe("! %s | ERROR. Can't find object in smarts_t and smart_id lists... | ID: %s", task_id, smart_id)
            end

            -- Unmark that object if it's was marked...
            raid_tasks_scout.unmark_smart(smart_id)
        end
        raid_tasks_scout.stmr = 0
        raid_tasks_scout.actor_on_update = function ()
            local tg = time_global()
            if raid_tasks_scout.stmr > tg then return end
            raid_tasks_scout.stmr = tg + 1000

            -- Original calls
            OLDGRASCOUTA()
            
            -- Get array and some condtions...
            local active_t = raid_tasks_main.raid_active_tasks
	        if not active_t or is_empty(active_t) then return end

            -- Iterating tasks.... And collecting the scouted dots
            for task_id, taskdata in pairs(active_t) do
		        if level.name() == taskdata.level_name and string.find(task_id, "scout", 1, true) then
                    for id, status in pairs(taskdata.smarts_t) do
                        -- Sync scouted dot(s)... Usually 1 but who knows...
                        if not taskdata.cachemp then taskdata.cachemp = {} end
                        if status == "scouted" and not taskdata.cachemp[id] then
                            local payload = { task_id, GameManager:GetServerIDByLocalID(id) }
                            GameManager:OnICustomScriptAction("raid_tasks_scout", "remote_scout_point", serialize_table_simple(payload), false)
                            taskdata.cachemp[id] = true
                        end
                    end
                end
            end
        end
        raid_tasks_scout_dunge.unmark_object = raid_tasks_scout.unmark_smart
        raid_tasks_scout_dunge.point_in_viewport = raid_tasks_scout.smart_in_viewport
        raid_tasks_scout_dunge.stmr = 0
        raid_tasks_scout_dunge.actor_on_update = function ()
            local tg = time_global()
	        if raid_tasks_scout_dunge.stmr > tg then return end
	        raid_tasks_scout_dunge.stmr = tg + 1000
            
            -- Original calls
            OLDGRASCOUTB()

            -- Get array and some condtions...
            local active_t = raid_tasks_dungeons.raid_dunge_active_tasks
	        if not active_t or is_empty(active_t) then return end

            -- Send item to host. Just for will he!
            if not IIsHost() then
                local section = "raid_intelligence_note"
                local item = db.actor:object(section)
                if item then
                    local str = "alife_create_item(%q, db.actor); news_manager.relocate_item(db.actor, 'in', %q)"
                    local cmd = string.format(str, section, section)
                    GameManager:OnICustomScriptAction(cmd, true)
                    news_manager.relocate_item(db.actor, 'out', section)
                    alife_release(item)
                    return
                end
            end

            -- Iterating tasks.... And collecting the active dots
            for task_id, taskdata in pairs(active_t) do
		        if level.name() == taskdata.level_name and string.find(task_id, "scout_dunge", 1, true) then
                    for id, status in pairs(taskdata.points) do
                        -- Sync scouted dot(s)... Usually 1 but who knows...
                        if not taskdata.cachemp then taskdata.cachemp = {} end
                        if status == "scouted" and not taskdata.cachemp[id] then
                            local payload = { task_id, GameManager:GetServerIDByLocalID(id) }
                            GameManager:OnICustomScriptAction("raid_tasks_scout", "remote_scout_point", serialize_table_simple(payload), false)
                            taskdata.cachemp[id] = true
                        end
                    end
                end
            end
        end
        raid_objects_arranger.get_object_rand_point = function (_, level_name, __, ___)
            local found_objects = {}
            local sim, gg = alife(), game_graph()
            for _, smart in pairs(SIMBOARD.smarts_by_names) do
                if smart and sim:level_name(gg:vertex(smart.m_game_vertex_id):level_id()) == level_name then
                    found_objects[#found_objects+1] = smart.id
                end
            end
            for _, binder in pairs(bind_campfire.campfires_all) do
                if binder and binder.object and sim:level_name(gg:vertex(binder.object:game_vertex_id()):level_id()) == level_name then
                    --table.insert(found_objects, binder.object:id())
                end
            end
            for name, zone in pairs(db.zone_by_name) do
                if zone and sim:level_name(gg:vertex(zone:game_vertex_id()):level_id()) == level_name then
                    --table.insert(found_objects, zone:id())
                end
            end
            if #found_objects == 0 then
                printe("ERROR: No objects found for raid_objects_arranger.get_object_rand_point")
                return nil
            end
            local random_index = math.random(1, #found_objects)
            return found_objects[random_index]
        end
        task_status_functor.raid_task_scout_dunge_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_dungeons.raid_dunge_active_tasks and raid_tasks_dungeons.raid_dunge_active_tasks[task_id]
            if not (db.actor and tsk and IIsHost()) then return end

            -- Use default status functor. It's good other parts at least for now.
            if tsk.stage ~= 0 then return OLDGRASCOUTC(tsk, task_id) end

            -- We not spawn the objects, we getting already existent
            local old_function = raid_objects_arranger.spawn_object_rand_point
            raid_objects_arranger.spawn_object_rand_point = raid_objects_arranger.get_object_rand_point
            -- Call raid functors
            local NeedSync = tsk.stage == 0
            local ret = OLDGRASCOUTC(tsk, task_id)
            -- Restore original
            raid_objects_arranger.spawn_object_rand_point = old_function
            if NeedSync then
                task_data = task_data or raid_tasks_dungeons.raid_dunge_active_tasks and raid_tasks_dungeons.raid_dunge_active_tasks[task_id]
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data })..", true", false)
            end
            return ret
        end
    end
