    if raid_task_anomaly_scan then
        raid_task_anomaly_scan.remote_reset_flag = function (task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not task_data then return end
            printf("~~~ [Server] Some player request to interrupt scanning...")
            task_data.scanner_placed = false
        end
        raid_task_anomaly_scan.remote_set_flag = function (task_id, time)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not task_data then return end
            printf("~~~ [Server] Some player request to begin scanning...")
            task_data.anomaly_scanner_placed_time = utils_data.CTime_to_table(game.get_game_time())
        	task_data.time_to_scan = time
            task_data.scanner_placed = true
            -- Do the spawn mutants maybe
            if math.random(1, 100) < 80 and IIsHost() then
				local squad = raid_task_anomaly_scan.spawn_mutant_for_scan()
				if squad then
					task_data.mutant_squad_id = squad.id
				else
					printf("! GRA Warning: failed to spawn mutant for scan, squad is nil")
				end
			end
            -- Send message to all... Due need it.
            local str = strformat(game.translate_string("anomaly_scan_task_begin"), ui_options.curr_player_name())
            news_manager.send_tip(db.actor, str, 0, "death", 5000)
        end
        task_functor.raid_task_anomaly_scan_target_functor = function(task_id,field,p,tsk)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (task_data and tsk) then return end
            if field == "title" then
                return raid_utils.get_raid_task_title(task_id, tsk.stage, 5)
            elseif field == "descr" then
                return raid_utils.get_raid_task_descr(task_id, tsk.stage, 5)
            elseif field == "target" and tsk.stage > 0 and task_data.item_sec then
                if tsk.stage == 5 then return end
                if not task_data.scanner_placed and not xr_conditions.actor_has_item(db.actor, db.actor, { task_data.item_sec }) then
                    return task_data.item_id
                end
                return task_data.smart_id
            end
        end
        task_status_functor.raid_task_anomaly_scan_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end
            if not IIsHost() and tsk.stage == 0 then return end
            
            local cur_time = game.get_game_time()
            local se_item = task_data and type(task_data.item_id) == "number" and alife_object(task_data.item_id)
            if tsk.stage ~= 0 and task_data and not se_item and not task_data.scanner_placed then -- Prevent every frame iterating if we have
                local item = task_data.item_sec and db.actor:object(task_data.item_sec)
                -- Return new or changed it if item was dropped by another player or like spawned
                if item then task_data.item_id = item:id() end
                return
            end

            -- We can't repeat the hacks like above or buttom due it's total closed and local...
            -- Maybe exist more easier way. But this too work. Animor: Quest stage synced properly.
            if tsk.stage == 0 and IIsHost() then
                local ret = OLDGRASCANER(tsk, task_id)
                task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                task_data.item_sec = "raid_anomaly_scanner"
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data }), false)
                return ret
            end

            -- IDK, but task_data can be null here...
            if not task_data then return end

            -- Probably but here we can't be sure that smart id not moved on client side.
            local smart = alife_object(task_data.smart_id)
            if not smart then
                printe("! %s | ERROR FAILED TO FIND SMART ZONE | ID %u !", task_id, task_data.smart_id)
                return
            end

            -- Reworked status for scanner place
            -- Stage 5 - is complete, 2 - is to early, 
            if not task_data.scanner_placed then
                local ndist = task_data.scanned_radius + 10
                if se_item and se_item.parent_id ~= 0 and db.actor:position():distance_to_sqr(smart.position) < ndist * ndist then
                    local time_rnd = math.random(60, 200)
                    GameManager:OnICustomScriptAction("raid_task_anomaly_scan", "remote_set_flag", string.format("%q", task_id)..","..tostring(time_rnd), false)
                    raid_task_anomaly_scan.remote_set_flag(task_id, time_rnd)
                    xr_sound.set_sound_play(db.actor:id(), "pda_beep_2")
                    tsk.stage = 3
                    return
                end
            else
                local item = task_data.item_sec and db.actor:object(task_data.item_sec)
                if item then
                    if tsk.stage == 5 and level.name() == raid_utils.raid_home_level then
                        raid_tasks_main.end_raid_task(task_id, "complete")
                    elseif tsk.stage == 4 then
                        tsk.stage = 5
                        xr_sound.set_sound_play(db.actor:id(), "pda_beep_2")
                    elseif tsk.stage == 3 then
                        GameManager:OnICustomScriptAction("raid_task_anomaly_scan", "remote_reset_flag", string.format("%q", task_id), false)
                        raid_task_anomaly_scan.remote_reset_flag(task_id)
                        tsk.stage = 2
                    end
                elseif tsk.stage == 5 then
                    tsk.stage = 4
                elseif tsk.stage ~= 4 and cur_time:diffSec(utils_data.CTime_from_table(task_data.anomaly_scanner_placed_time)) > task_data.time_to_scan then
                    local str = strformat(game.translate_string("anomaly_scan_task_update"), ui_options.curr_player_name())
                    news_manager.send_tip(db.actor, str, 0, "death", 5000)
                    tsk.stage = 4
                end
            end

            -- fail on timer
            if task_data.urgent and task_data.urgent < 9 and IIsHost() then
                local hours = raid_tables.raid_urgency_time[task_data.urgent]
                if hours and cur_time:diffSec(utils_data.CTime_from_table(task_data.start_time)) > hours * 3600 then
                    raid_tasks_main.end_raid_task(task_id, "fail")
                end
            end
        end
    end
    if raid_task_kill_and_delivery_out then
        task_status_functor.raid_task_kill_stalker_and_delivery_out_status_functor = function(tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end

            -- Clients no need more than this... Haha host...
            if not IIsHost() then
                if task_data then
                    local item = task_data.pick_up_item_sec and db.actor:object(task_data.pick_up_item_sec) or task_data.item_sec and db.actor:object(task_data.item_sec)
                    if item then
                        -- Transfer all to host. We can't manage that!
                        task_data.item_id = 65535
                        local sec = item:section()
                        local str = "alife_create_item(%q, db.actor); news_manager.relocate_item(db.actor, 'in', %q)"
                        local cmd = string.format(str, sec, sec)
                        GameManager:OnICustomScriptAction(cmd, true)
                        news_manager.relocate_item(db.actor, 'out', sec)
                        alife_release(item)
                        -- Send updated task msg...
                        local str = strformat(game.translate_string("kill_stalker_and_delivery_out_task_update_2"))
			            news_manager.send_tip(db.actor, str, 0, "death", 5000)
			            xr_sound.set_sound_play(db.actor:id(), "pda_beep_2")
                    end
                end
                return
            end

            -- This block iterates the player and erases object if we have one than going to stage 6 forcelly
            if tsk.stage == 5 and task_data then
                local item = task_data.pick_up_item_sec and db.actor:object(task_data.pick_up_item_sec)
                if item then
                    -- Return new or changed it if item was dropped by another player or like spawned
                    task_data.pick_up_item_id = item:id()
                    local str = strformat(game.translate_string("kill_stalker_and_delivery_out_task_update_2"))
			        news_manager.send_tip(db.actor, str, 0, "death", 5000)
			        xr_sound.set_sound_play(db.actor:id(), "pda_beep_2")
			        tsk.stage = 6
                    return
                end
            elseif tsk.stage == 7 or tsk.stage == 8 and task_data then
                local item = task_data.item_sec and db.actor:object(task_data.item_sec)
                if item then
                    -- Return new or changed it if item was dropped by another player or like spawned
                    task_data.item_id = item:id()
                    tsk.stage = 9
                end
            elseif tsk.stage == 2 and task_data and task_data.stalker_killed then
                local str = strformat(game.translate_string("kill_stalker_and_delivery_out_task_update_1"), ui_options.curr_player_name())
                news_manager.send_tip(db.actor, str, 0, "death", 9000)
                xr_sound.set_sound_play(db.actor:id(), "pda_beep_2")
                task_data.is_display = task_data.killed_by_actor
                tsk.stage = 3
                return
            end

            local NeedSync = tsk.stage == 0 or tsk.stage == 4 or tsk.stage == 6

            -- Original code.
            math.random = NEWRANDOMRT
            local ret = OLDGRAKILLSA(tsk, task_id)
            math.random = OLDRANDOMRT

            -- Sync after stage 0 or 6
            if NeedSync and IIsHost() then
                task_data = task_data or raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                local se_item = task_data.item_id and alife_object(task_data.item_id)
                task_data.item_sec = se_item and se_item:section_name()
                task_data.pick_up_item_sec = "raid_item_with_stash"
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data }), false)
            end
            return ret
        end
    end
    if raid_task_rf_find_and_delivery_out then
        task_status_functor.raid_task_rf_find_and_delivery_out_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end

            -- Stage 2 and check for need item obj blah
            if tsk.stage ~= 0 and task_data then
                local item = task_data.item_sec and db.actor:object(task_data.item_sec)
                if item then
                    if not IIsHost() then
                        -- Transfer all to host. We can't manage that!
                        task_data.item_id = 65535
                        local str = "alife_create_item(%q, db.actor); news_manager.relocate_item(db.actor, 'in', %q)"
                        local cmd = string.format(str, task_data.item_sec, task_data.item_sec)
                        GameManager:OnICustomScriptAction(cmd, true)
                        news_manager.relocate_item(db.actor, 'out', task_data.item_sec)
                        alife_release(item)
                        return
                    end
                    -- Return new or changed it if item was dropped by another player or like spawned
                    task_data.item_id = item:id()
                    if level.name() == raid_utils.raid_home_level then
                        raid_tasks_main.end_raid_task(task_id, "complete")
                        return
                    end
                end
            end

            -- Host can setup data for quest. But client need to search position maybe
            if not IIsHost() then
                if (tsk.stage == 0 or tsk.stage == 5 or tsk.stage == 3 or tsk.stage == 4 or not task_data) then return end
                if task_data.item_id and alife_object(task_data.item_id) then
                    task_data.stash_id = task_data.item_id
                elseif task_data.smart_id and alife_object(task_data.smart_id) then
                    task_data.stash_id = task_data.smart_id
                else -- Can't find smart or stash id
                    return
                end
            end

            -- Host can setup data for quest
            local NeedSync = tsk.stage == 0
            local NeedSyncMark = tsk.stage == 2 and task_data and task_data.stash_id and level.map_has_object_spot(task_data.stash_id, "treasure") == 0

            -- Iterate pos based players
            math.random = NEWRANDOMRT
            if tsk.stage == 1 and IIsHost() then
                local oldactor = actor
                for k, v in pairs(db.actors) do
                    if v and v.object then
                        actor = v.object
                        OLGRARFFDLVR(tsk, task_id)
                    end
                end
                actor = oldactor
            end

            -- Default call for setup
            local ret = OLGRARFFDLVR(tsk, task_id)
            math.random = OLDRANDOMRT

            NeedSyncMark = task_data and task_data.stash_id and level.map_has_object_spot(task_data.stash_id, "treasure") ~= 0

            -- Sync if it's was stage == 0
            if IIsHost() then
                task_data = task_data or raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                if NeedSync then
                    local se_object = alife_object(task_data.smart_id) or alife_object(task_data.stash_id) or alife_object(task_data.item_id)
                    if se_object then 
                        task_data.target_position = { se_object.position.x, se_object.position.y, se_object.position.z, se_object.position.w }
                        for _, t in pairs(raid_tasks_main.raid_tasks_t) do
                            if t.tasks[task_id] then
                                task_data.target_freq = t.tasks[task_id].target_freq
                                break
                            end
                        end
                    else
                        printe("! [Server] Failed to set position for client side. Due we can't find any of this object!")
                    end
                    GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data }), false)
                elseif NeedSyncMark then
                    local se_box = task_data.stash_id and alife_object(task_data.stash_id)
                    if not se_box then
                        printe("! [Server] Failed to sync mark of %s stash!", task_data.stash_id or 65535)
                        return
                    end
                    local payload = { se_box.id, se_box.position, se_box.m_level_vertex_id, se_box.m_game_vertex_id, treasure_manager.get_stash_spot_type(se_box.id) }
                    GameManager:OnICustomScriptAction("treasure_manager", "remote_add_map_spot", serialize_table_simple(payload), false)
                end
            end
            return ret
        end
    end
    if raid_task_rf_scout_and_delivery_out then
        task_status_functor.raid_task_rf_scout_and_delivery_out_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end
            -- Host thing that if we got item somehow return it to host
            -- Stage 2 and check for need item obj blah
            if tsk.stage ~= 0 and task_data then
                local item = task_data.item_sec and db.actor:object(task_data.item_sec)
                if item then
                    if not IIsHost() then
                        -- Transfer all to host. We can't manage that!
                        task_data.item_id = 65535
                        local str = "alife_create_item(%q, db.actor); news_manager.relocate_item(db.actor, 'in', %q)"
                        local cmd = string.format(str, task_data.item_sec, task_data.item_sec)
                        GameManager:OnICustomScriptAction(cmd, true)
                        news_manager.relocate_item(db.actor, 'out', task_data.item_sec)
                        alife_release(item)
                        return
                    end
                    -- Return new or changed it if item was dropped by another player or like spawned
                    task_data.item_id = item:id()
                    if level.name() == raid_utils.raid_home_level then
                        raid_tasks_main.end_raid_task(task_id, "complete")
                        return
                    end
                end
            end

            -- Host can setup data for quest. But client need to search position maybe
            if not IIsHost() and (tsk.stage == 0 or tsk.stage == 4 or tsk.stage == 3 or not task_data) then return end

            -- Host can setup data for quest
            local NeedSync = tsk.stage == 0
            local NeedSyncMark = task_data and task_data.stash_id and level.map_has_object_spot(task_data.stash_id, "treasure") == 0

            -- Iterate pos based players
            math.random = NEWRANDOMRT
            if tsk.stage == 1 and IIsHost() then
                local oldactor = actor
                for k, v in pairs(db.actors) do
                    if v and v.object then
                        actor = v.object
                        OLGRARFFDRVR(tsk, task_id)
                    end
                end
                actor = oldactor
            end
            
            -- Default call for setup
            local ret = OLGRARFFDRVR(tsk, task_id)
            math.random = OLDRANDOMRT

            NeedSyncMark = task_data and task_data.stash_id and level.map_has_object_spot(task_data.stash_id, "treasure") ~= 0
            
            -- Sync if it's was stage == 0
            if IIsHost() then
                task_data = task_data or raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                if NeedSync then
                    local se_object = alife_object(task_data.smart_id) or alife_object(task_data.stash_id) or alife_object(task_data.item_id)
                    if se_object then 
                        task_data.target_position = { se_object.position.x, se_object.position.y, se_object.position.z, se_object.position.w }
                        for _, t in pairs(raid_tasks_main.raid_tasks_t) do
                            if t.tasks[task_id] then
                                task_data.target_freq = t.tasks[task_id].target_freq
                                break
                            end
                        end
                    else
                        printe("! [Server] Failed to set position for client side. Due we can't find any of this object!")
                    end
                    GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data }), false)
                elseif NeedSyncMark then
                    local se_box = task_data.stash_id and alife_object(task_data.stash_id)
                    if not se_box then
                        printe("! [Server] Failed to sync mark of %s stash!", task_data.stash_id or 65535)
                        return
                    end
                    local payload = { se_box.id, se_box.position, se_box.m_level_vertex_id, se_box.m_game_vertex_id, treasure_manager.get_stash_spot_type(se_box.id) }
                    GameManager:OnICustomScriptAction("treasure_manager", "remote_add_map_spot", serialize_table_simple(payload), false)
                end
            end
            return ret
        end
    end
    if raid_tasks_deliveries then
        task_status_functor.raid_task_delivery_in_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end
            -- Some fixes due it's something wrong
            if tsk.stage ~= 0 and tsk.stage ~= 3 and task_data then
                local stash_obj = level.object_by_id(task_data.stash_id)
                if stash_obj then
                    local item = stash_obj:object(task_data.item_sec)
                    if item then 
                        alife_release(item)
                        tsk.stage = 3
                    elseif not xr_conditions.actor_has_item(db.actor, db.actor, { task_data.item_sec }) then
                        tsk.stage = 2
                    else
                        tsk.stage = 1
                    end
                end
            end

            -- Status other stuff
            if not IIsHost() and tsk.stage == 0 then return end
            local NeedSync = tsk.stage == 0
            math.random = NEWRANDOMRT
            local ret = OLDGRADELISI(tsk, task_id)
            math.random = OLDRANDOMRT

            -- Sync if it's was stage == 0
            if NeedSync and IIsHost() then
                task_data = task_data or raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", serialize_table_simple({ task_id, task_data }), false)
            end
            return ret
        end
    end
    if raid_sudden_task_find_squad_and_delivery_out then
        task_status_functor.raid_sudden_task_find_squad_and_delivery_out_status_functor = function (tsk, task_id)
            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
            if not (db.actor and tsk) then return end

            -- Status other stuff
            if not IIsHost() then return end
            local NeedSync = tsk.stage == 0
            local ret = OLGRARFFSQIT(tsk, task_id)

            -- Sync if it's was stage == 0
            if NeedSync and IIsHost() then
                task_data = task_data or raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                local se_object = alife_object(task_data.smart_id) or alife_object(task_data.stash_id) or alife_object(task_data.item_id)
                if se_object then
                    task_data.target_position = { se_object.position.x, se_object.position.y, se_object.position.z, se_object.position.w }
                    for _, t in pairs(raid_tasks_main.raid_tasks_t) do
                        if t.tasks[task_id] then
                            task_data.target_freq = t.tasks[task_id].target_freq
                            break
