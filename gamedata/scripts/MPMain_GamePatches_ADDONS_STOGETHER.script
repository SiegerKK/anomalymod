    if placeable_furniture then
        placeable_furniture.cleanup_remote = function (id)
            local m_data = alife_storage_manager.get_state()
            if not m_data then return end
            local StashID = nil
            if m_data.workshop_stashes then
                StashID = m_data.workshop_stashes[id]
                m_data.workshop_stashes[id] = nil
            elseif m_data.stove_stashes then
                StashID = m_data.stove_stashes[id]
                m_data.stove_stashes[id] = nil
            end
            if IIsHost() and StashID then alife_release_id(StashID) end
        end
        placeable_furniture.pickup_obj = function(obj)
            if not obj then return end
            GameManager:OnICustomScriptAction("placeable_furniture", "cleanup_remote", tostring(obj:id()), false)
            if not IIsHost() then alife_release_client(obj) end
            return OLDPICKUPFU(obj)
        end
        placeable_furniture.SyncFurnitureData = function(gdata)
            local loc_id = GameManager:GetLocalIDByServerID(gdata[1])
            hf_obj_manager.set_data(loc_id, gdata[2])
            local obj = level.object_by_id(loc_id)
            if obj then
                -- Callback flags
                SendScriptCallback("hf_on_furniture_spawn", loc_id)
                SendScriptCallback("hf_on_furniture_place", loc_id)
            end
        end
        function bind_hf_base.hf_binder_wrapper:is_pickupable()
            local data = hf_obj_manager.get_data(self.object:id())
            return not data or not data.is_world_obj
        end
        function bind_hf_base.hf_binder_wrapper:pickup()
            local item_section = ini_sys:r_string_ex(self.object:section(), "item_section")
            local condition = self.fuel
            alife_create_item(item_section, db.actor, {cond=condition}) -- Maybe transfer all data to new item? Probably depends on item type tho

            -- Clean up HF-related data
            hf_obj_manager.cleanup_data(self.object:id())
            alife_release_client(self.object)

            return true
        end
        function bind_hf_base.hf_binder_wrapper:net_spawn(se_abstract)
            if not object_binder.net_spawn(self, se_abstract) then
                return false
            end
            -- FREEZE OBJECT AFTER SPAWN IMMEDIATLY
            CreateTimeEvent(self.object:id(), "hf_freeze", 0, bind_hf_base.freeze_obj, self.object:id())
            -- SYNC DATA.
            if not IIsHost() then return end
            local gdata = hf_obj_manager.get_data(self.object:id())
            if gdata then
                local payload = { self.object:id(), gdata }
                GameManager:OnICustomScriptAction("placeable_furniture", "SyncFurnitureData", serialize_table_simple(payload), false)
            end
        end
        if bind_hf_static then
            function bind_hf_static.hf_static_binder:net_spawn(se_abstract)
                if not(object_binder.net_spawn(self, se_abstract)) then
                    return false
                end
                -- FREEZE OBJECT AFTER SPAWN IMMEDIATLY
                CreateTimeEvent(self.object:id(), "hf_freeze", 0, bind_hf_static.freeze_obj, self.object:id())
                -- SYNC DATA.
                if not IIsHost() then return end
                local gdata = hf_obj_manager.get_data(self.object:id())
                if gdata then
                    local payload = { self.object:id(), gdata }
                    GameManager:OnICustomScriptAction("placeable_furniture", "SyncFurnitureData", serialize_table_simple(payload), false)
                end
                return true
            end
        end
        placeable_furniture.create_object = function(section_or_table, location, rotation, lvid, gvid)
            if not section_or_table then
                printf("Could not find associated object with item")
                return
            end

            location = location or vector():set(0,0,0)
            rotation = rotation or vector():set(0,0,0)

            if rotation.w then rotation = rotation:to_euler_angles() end

            -- Requesting host to spawn anomaly fucks with big diametters
            if not IIsHost() then
                local payload = { section_or_table, location, rotation, lvid, gvid }
                GameManager:OnICustomScriptAction("placeable_furniture", "create_object", serialize_table_simple(payload), true)
                return
            end

            -- Convert to basic types!
            if type(section_or_table) == "table" then
                local mpos = section_or_table[2]
                local mrot = section_or_table[3]
                location = vector():set(mpos[1],  mpos[2], mpos[3])
                rotation = vector():set(mrot[1],  mrot[2], mrot[3])
                lvid = section_or_table[4]
                gvid = section_or_table[5]
                section_or_table = section_or_table[1]
            end

            -- Save local var that stash looted.. Due lmao
            return OLDPLACEFUR(section_or_table, location, rotation, lvid, gvid)
        end
        if z_auto_looter then z_auto_looter.auto_looter = NOP end
