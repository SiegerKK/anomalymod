            local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
	        if not (db.actor and tsk and IIsHost()) then return end
            if task_data then
                if not task_data.wpn_cond then task_data.wpn_cond = task_data.outf_cond or task_data.art_tier end
                if task_data.found_item_id then
                    -- End task and sync money
