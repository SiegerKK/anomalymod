        function raid_map_gui.RaidMap:OnClickMap(level_name)
            if IIsHost() then self.clicked_map_await = level_name end
            if self.clicked_map_await and self.clicked_map_await == level_name then
                self:HideAll()
	            self.details_bg:Show(true)
	            self:UpdateMapDetails(level_name)
                return
            end
            local payload = { GameManager:GetMySNETID(), level_name }
            GameManager:OnICustomScriptAction("raid_map_gui", "request_events_data", serialize_table_simple(payload), true)
            self.clicked_map_await = level_name
        end
        function raid_map_gui.RaidMap:OnClickMapInformantOption(idx)
            local money = db.actor:money()
            OLDGRAMAPGUI(self, idx)
            if not IIsHost() then -- UGLY HACK...
                local delta = money - db.actor:money()
                GameManager:OnICustomScriptAction("db.actor:give_money(".. tostring(delta)..")", true)
                GameManager:OnICustomScriptAction("raid_map_gui", "request_informant_data", serialize_table_simple({ self.clicked_map_await, idx }), true)
                return
            end
            local eventst = raid_events.raid_active_events[raid_map_gui.picked_map]
            local payload = { raid_map_gui.picked_map, eventst, false }
            GameManager:OnICustomScriptAction("raid_map_gui", "receive_events_data", serialize_table_simple(payload), false)
        end
        raid_map_gui.receive_events_data = function (tbl)
            local GUIS = raid_map_gui.get_ui_silent()
            if not GUIS then return end
            printf("[Client] Updating raid events data!")
            local level_name = tbl[1]
            raid_events.raid_active_events[level_name] = tbl[2]
            if not tbl[3] then
                -- If we have opened map need to update state
                if GUIS.clicked_map_await then
                    GUIS:UpdateMapDetails(GUIS.clicked_map_await)
                end
                return
            end
            -- Real open action of map data
	        GUIS:OnClickMap(level_name)
        end
        raid_map_gui.request_events_data = function (tbl)
            local GUIS = raid_map_gui.get_ui_silent()
            if not GUIS then return end
            local level_name = tbl[2]
            printf("[Server] Player request events for [%s] map!", level_name)
            local payload = { level_name, raid_events.raid_active_events[level_name], true }
            GameManager:OnICustomScriptAction("raid_map_gui", "receive_events_data", serialize_table_simple(payload), false, tbl[1])
        end
        raid_map_gui.request_informant_data = function (tbl)
            local GUIS = raid_map_gui.get_ui_silent()
            if not GUIS then return end
            local level_name = tbl[1]
            local idx = tbl[2]
            printf("[Server] Player request informant for [%s][%i] informant!", level_name, idx)
            -- Do update from informant related to our map and clear it...
            local last_name = raid_map_gui.picked_map
            raid_map_gui.picked_map = level_name
            GUIS:OnClickMapInformantOption(idx)
            raid_map_gui.picked_map = last_name
            treasure_manager.sync_all_stashes()
        end
    end
