            local hud = get_hud()
            if hud then
                hud:AddCustomStatic("text_on_screen_center", true)
                local static = hud:GetCustomStatic("text_on_screen_center")
                if static then
                    static:wnd():TextControl():SetText("CLIENT CAN'T ACCEPT THIS TYPE OF TASK\n PLEASE DROP IT TO HOST")
                    CreateTimeEvent(0, "remove_warn_travel", 3, function()
                        hud:RemoveCustomStatic("text_on_screen_center")
                        return true
                    end)
                end
            end
            self:OnMsgCancel()
        end
    end
