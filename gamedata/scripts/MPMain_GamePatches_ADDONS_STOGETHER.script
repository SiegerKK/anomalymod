-- RAID TASKS HACKS RANDOM STILL CAN MAKE SAME ITEMS
local USEDNUMRNDT = {}
local OLDRANDOMRT = math.random
function NEWRANDOMRT(startl, endl)
    local num = startl and endl and OLDRANDOMRT(startl, endl) or startl and OLDRANDOMRT(startl) or OLDRANDOMRT()
    if USEDNUMRNDT[num] then
        -- Just anti cycle overflow freeze.
        printf("! COOP: STOGETHER : %s | NUM WAS OBTAINED", num)
        USEDNUMRNDT[num] = false
        return NEWRANDOMRT(startl, endl)
    end
    printf("! COOP: STOGETHER : %s | NUM WAS GENERATED", num)
    USEDNUMRNDT[num] = true
    return num
end

