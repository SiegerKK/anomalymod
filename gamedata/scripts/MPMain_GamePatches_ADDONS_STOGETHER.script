                local section = SYS_GetParam(0, obj:section(), "integrated_storage")
                se_inv_box = alife_create(section, pos, obj:level_vertex_id(), obj:game_vertex_id())
                if se_inv_box then
                    -- force strictly online (not sure this is needed)
                    alife():set_switch_online(se_inv_box.id, true)
                    alife():set_switch_offline(se_inv_box.id, false)
                    -- Save container
                    m_data.stove_stashes[id] = se_inv_box.id
