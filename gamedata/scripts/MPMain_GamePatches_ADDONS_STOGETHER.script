            -- Show message
            local hud = get_hud()
            if hud then
                -- If host teleporting need to send message that event is sent.
                -- For players to prevent click map again due like happens nothing
                hud:AddCustomStatic("text_on_screen_center", true)
                local static = hud:GetCustomStatic("text_on_screen_center")
                if static then
                    static:wnd():TextControl():SetText("Please wait host is teleporting to raid!")
