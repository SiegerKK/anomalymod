            local id = obj:id()
            -- Instantiate container
            local se_container = ultimate_backpacks_manager.get_container(id, true)
            if not se_container then return false end
            CreateTimeEvent(id, "open_inventory", 1, function ()
                -- Waiting for my items...
                if not GameManager:IsStashFirstFilled(se_container.id) then
                    GameManager:OnIStashOpen(se_container.id, false)
