function on_game_start()
    if raid_utils and raid_notebook_gui_shelter and raid_notebook_gui_items and raid_tasks_main and raid_main then
        -- Register raid sync values
        RegisterScriptCallback("onmp_player_connected_server", function(PlayerNetID, nick)
            -- This is big arrays, need to wait for buffer flush in another thread of steam.
            CreateTimeEvent(PlayerNetID, "raid_utils_sync", 1, function()
                local upgrades_payload = serialize_table_simple(raid_notebook_gui_shelter.raid_shelter_upgrades)
                local riditems_payload = serialize_table_simple(raid_notebook_gui_items.raid_items)
                local taskdata_payload = serialize_table_simple(raid_tasks_main.raid_active_tasks)
                local taskdung_payload = serialize_table_simple(raid_tasks_dungeons.raid_dunge_active_tasks)..", true"
                local rewardsi_payload = serialize_table_simple(raid_utils.money_to_sync)
                local timerstr_payload = tostring(raid_main.raid_timer)
                -- Sync raid got upgrades
                GameManager:OnICustomScriptAction("raid_notebook_gui_shelter.raid_shelter_upgrades = " .. upgrades_payload, false, PlayerNetID)
                -- Sync raid bough ritems
                GameManager:OnICustomScriptAction("raid_notebook_gui_items.raid_items = " .. riditems_payload, false, PlayerNetID)
                -- Sync raid task rewards
                if LastSyncMoney ~= PlayerNetID then
                    GameManager:OnICustomScriptAction("raid_utils", "sync_raid_reward", rewardsi_payload, false, PlayerNetID)
                    LastSyncMoney = PlayerNetID
                end
                -- Sync active tasks vars
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", taskdata_payload, false, PlayerNetID)
                GameManager:OnICustomScriptAction("raid_utils", "sync_task_vars", taskdung_payload, false, PlayerNetID)
                -- Sync raid surgem timer
                if level.name() ~= "fake_start" then
                    GameManager:OnICustomScriptAction("raid_main.raid_timer = " .. timerstr_payload, false, PlayerNetID)
                end
                return true
            end)
        end)
    end
end