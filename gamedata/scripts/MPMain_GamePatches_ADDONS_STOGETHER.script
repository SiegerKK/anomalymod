        guards_spawner.load_state = NOP
        guards_spawner.save_state = function(m_data)
            m_data.guarded_smarts = {}
            m_data.prev_time = nil
        end
        guards_spawner.on_enemy_eval = NOP
    end
    -- USELES PORTIONS. HOST CAN USE IT
    if task_brotherhood then
