                local box = stash_id and level.object_by_id(stash_id)
                if not box or not IsInvbox(box) then return false end
                if not GameManager:IsStashFirstFilled(stash_id) then
                    GameManager:OnIStashOpen(stash_id, false)
                    return false
                end
                item_cooking.start(obj, "fieldcooker")
                return true
            end)
            self:Close()
            return true
        end
