    if raid_simulation_lab then
        raid_simulation_lab.create_lab_restrictors = function ()
            if not IIsHost() then return end
            for lab_name, r_sim in pairs(raid_simulation_lab.raid_restr_lab) do 
                for tier_name, r_zones in pairs(r_sim) do 
                    for zone_name, zone in pairs(r_zones) do
                        local size_x = zone.p2.x - zone.p1.x
                        local size_y = zone.p2.y - zone.p1.y
                        local size_z = zone.p2.z - zone.p1.z
                        local pos = vector():set(zone.p1.x + size_x / 2, zone.p1.y + size_y / 2, zone.p1.z + size_z / 2)
                        local se_obj = alife_create("raid_lab_restrictor_" .. tier_name, pos, zone.lvid, zone.gvid)
                        if se_obj then
                            local data = utils_stpk.get_space_restrictor_data(se_obj)
                            if data then
                                data.shapes = {}
                                data.shapes[1] = {}
                                data.shapes[1].shtype = 1
                                data.shapes[1].v1 = vector():set(size_x, 0, 0)
                                data.shapes[1].v2 = vector():set(0, size_y + zone.size.y, 0)
                                data.shapes[1].v3 = vector():set(0, 0, size_z)
                                data.shapes[1].offset = vector():set(0, 0, 0)
                                local strcs = string.format([[
                                    [logic]
                                    active = sr_idle@run

                                    [sr_idle@run]
                                    on_info = %% =raid_restr_lab_restrictor_run(%s:%s) %%
                                ]], se_obj:name(), tier_name)
                                data.custom_data = strcs
                            end
                            utils_stpk.set_space_restrictor_data(data, se_obj)
                        end
                    end
                end
            end
        end
        xr_effects.raid_restr_lab_restrictor_run = function (actor, npc, p)
            if not (IIsHost() and p) then return false end
            if raid_simulation_lab.tiers_lab_is_spawned[p[2]] then return true end
            -- Iterate only one zone and check conds
            local name = p[1]
            local tier = p[2]
            local zone = db.zone_by_name[name]
            if not zone then return false end
            -- MC in zone
            if zone:inside(actor:position()) then
                printf("[Client] Player [%s] triggered the [%s][%s] zone", ui_options.curr_player_name(), name, tier)
                raid_simulation_lab.lab_spawn(tier)
                return true
            end
            -- Check other players in zone...
            for _, v in pairs(db.actors) do
                if v and v.object and zone:inside(v.object:position()) then
                    printf("[Client] Player [%s] triggered the [%s][%s] zone", v.object:name(), name, tier)
                    raid_simulation_lab.lab_spawn(tier)
                    return true
                end
            end
            return false
        end
    end
    if raid_travel_manager then
        function ui_sr_teleport.msg_box_ui:ModdedMPTeleport()
            if not self.name then return end

            -- return if blacklisted
            if raid_travel_manager.out_blacklisted_restr_t[self.name] then
                actor_menu.set_msg(1, game.translate_string("st_route_unknown"),5)
                ui_sr_teleport.msg_box_ui.OnMsgCancel(self)
                return
            end

            -- return if transition is blocked
            if raid_simulation_dungeons.raid_sim_dunge[level.name()] then
                if z_raid_item_travel_dungeons.nearest_restrictor_id then
                    local se_obj = alife_object(z_raid_item_travel_dungeons.nearest_restrictor_id)
                    if se_obj and se_obj:name() == self.name then
                        actor_menu.set_msg(1, game.translate_string("st_raid_route_unavailable"),5)
                        ui_sr_teleport.msg_box_ui.OnMsgCancel(self)
                        return
                    end
                end
            end
            
            -- Raid home position_data
            local pos = vector():set(618.37, -43.845, 197.48)
            local look = vector():set(622.48, -43.8, 195.15)
            local lvid = 222305
            local gvid = 2531
            
            --teleport to home
            printf("raid_teleport, tp to home level")

            local dir = vector():set(vec_sub(look, pos):normalize())

            db.actor:hide_weapon()
        
            -- change time
            CreateTimeEvent("raid_time_forward_e", "raid_time_forward_a", 2.5, function()
                local tier = raid_utils.get_raid_sim(level.name()) and raid_utils.get_raid_sim(level.name()).level_tier or 1
                local hour = raid_utils.calc_travel_time(tier)

                -- hit radiation + bleeding travel
                local rad_hit = raid_utils.raid_get_rad_hit(hour)
                raid_rad_hit_damage = rad_hit
                local bleeding_hit = db.actor.bleeding / 1.7
                
                -- Health damage
                db.actor.health = db.actor.health - rad_hit - bleeding_hit
                db.actor.radiation = 0
                db.actor.bleeding = 999
                arszi_psy.set_psy_health(1)
                
                -- Set flags idk why
                if db.actor.health <= 0 and bleeding_hit <= 0.03 then
                    raid_travel_manager.flag_died_radiation_during_travel = true
                elseif (rad_hit >= 0.05) then
                    raid_travel_manager.flag_hit_radiation_during_travel = true			
                end

                -- Changing weather and times
                level.change_game_time(0, hour, 0)
                raid_travel_manager.weather_change()
                return true
            end)

            -- teleport fade screen
            level.add_pp_effector("sleep_fade.ppe", 1313, false)
            CreateTimeEvent("raid_delay_travel_e", "raid_delay_travel_a", 3, function()
                ChangeLevel(pos, lvid, gvid, VEC_ZERO)
                return true
            end)

            SendScriptCallback("on_before_level_changing")
        end
    end
    if grok_loot_claim then
        grok_loot_claim.npc_on_death_callback = function (victim, killer)
            if not (victim and killer) then return end
            if IsActor(killer) and killer:id() ~= db.actor:id() then return end
            return OLDLRCLAIMSP(victim, killer)
        end
    end
    if demonized_ledge_grabbing and not demonized_ledge_grabbing.grap_in_tsync then
        demonized_ledge_grabbing.grap_in_tsync = function()
            CreateTimeEvent(0, "act_climb_start_sync", 1.1, function()
                GameManager:OnICustomAnimation("turnik_out", "", true, 1)
                return true
            end)
        end
        RegisterScriptCallback("actor_on_climb_start", demonized_ledge_grabbing.grap_in_tsync)
