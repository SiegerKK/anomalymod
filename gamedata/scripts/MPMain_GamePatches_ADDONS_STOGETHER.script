        raid_utils.sync_raid_reward = function (tbl)
            for task_id, money in pairs(tbl) do
                local task_data = raid_tasks_main.raid_active_tasks and raid_tasks_main.raid_active_tasks[task_id]
                task_data = task_data or raid_tasks_dungeons.raid_dunge_active_tasks and raid_tasks_dungeons.raid_dunge_active_tasks[task_id]
                if task_data then
                    local summ = money / math.random(2, 8)
                    db.actor:give_money(summ)
                    news_manager.relocate_money(db.actor, "in", summ)
                end
            end
        end
