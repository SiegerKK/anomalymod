    if raid_utils then
        raid_utils.kill_task_cond = function (squad, se_obj, killer)
            if not squad or not se_obj or not killer then return end
            local self_killer = killer.id == se_obj.id
            local friendly_fire = raid_utils.obj_in_squad(killer.id, squad.id)
            local obj = level.object_by_id(killer.id)
            local comp_killer = obj and obj:has_info("npcx_is_companion")

            return IsActor(killer) or IsAnomaly(killer) or self_killer or friendly_fire or comp_killer
        end
        raid_utils.sync_task_vars = function (tbldata, scout)
            local type_ = type
            -- We have stupid id system, we need convert SID to CID
            for k, v in pairs(tbldata) do
                -- Convert ids back to local ids
                if type_(v.stalker_id) == "number" then v.stalker_id = GameManager:GetLocalIDByServerID(v.stalker_id) end
                if type_(v.smart_id) == "number" then v.smart_id = GameManager:GetLocalIDByServerID(v.smart_id) end
                if type_(v.squad_id) == "number" then v.squad_id = GameManager:GetLocalIDByServerID(v.squad_id) end
                if type_(v.stash_id) == "number" then v.stash_id = GameManager:GetLocalIDByServerID(v.stash_id) end
                if type_(v.item_id) == "number" then v.item_id = GameManager:GetLocalIDByServerID(v.item_id) end
                -- Convert dots to local ids
                if v.smarts_t then
                    local tblc = {}
                    for id, status in pairs(v.smarts_t) do
                        local locid = GameManager:GetLocalIDByServerID(id)
                        tblc[locid] = status
                        if status == "active" then
                            raid_tasks_scout.mark_smart(locid)
                        end
                    end
                    v.smarts_t = tblc
                elseif v.points then
                    local tblc = {}
                    for id, status in pairs(v.points) do
                        local locid = GameManager:GetLocalIDByServerID(id)
                        tblc[locid] = status
                        if status == "active" then
                            raid_tasks_scout.mark_smart(locid)
                        end
                    end
                    v.points = tblc
                end
                -- Save var to raid table!
                if scout then
                    raid_tasks_dungeons.raid_dunge_active_tasks[k] = v
                else
                    raid_tasks_main.raid_active_tasks[k] = v
                end
            end
        end
    end
