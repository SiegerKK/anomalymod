        function task_manager.CRandomTask:task_fail(p1)
            if not db.actor or device().precache_frame > 1 then return false end
            local tsk = self.task_info[p1]
            if not tsk then
                printe("!ERROR: CRandomTask:task_fail %s task is nil!", p1)
                return false
            end
            if tsk.forced_status == "fail" then
                tsk.forced_status = nil
                tsk.last_check_task = "fail"
            end
            return tsk.last_check_task == "fail"
        end
    end
