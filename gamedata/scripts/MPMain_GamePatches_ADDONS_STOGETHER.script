    if ultimate_backpacks_manager then
        ultimate_backpacks_manager.sync_container = function (tblb)
            local m_data = alife_storage_manager.get_state()
            if not m_data then return end
            if not m_data.ub_backpack_containers then m_data.ub_backpack_containers = {} end
            if not m_data.ub_backpack_backpacks then m_data.ub_backpack_backpacks = {} end
            for k, v in pairs(tblb) do
                local stash_id = GameManager:GetLocalIDByServerID(k)
                --tbln[GameManager:GetLocalIDByServerID(k)] = stash_id
                m_data.ub_backpack_containers[v] = { id = stash_id }
                m_data.ub_backpack_backpacks[k] = v
            end
        end
        ultimate_backpacks_manager.get_container = function(id, netid)
            -- Dirty hack to avoid that netid wrong arguments
            if type(netid) == "boolean" then netid = false end
            local m_data = alife_storage_manager.get_state()
            if not m_data then return end
            if not m_data.ub_backpack_containers then m_data.ub_backpack_containers = {} end
            if not m_data.ub_backpack_backpacks then m_data.ub_backpack_backpacks = {} end
            local se_data = m_data.ub_backpack_containers and m_data.ub_backpack_containers[id]
            local se_inv_box = se_data and se_data.id and alife_object(se_data.id)
            if not se_inv_box or not IsInvbox(se_inv_box) then
                -- JUST IF REALLY NOT EXIST
                if not IIsHost() then
                    GameManager:OnICustomScriptAction("ultimate_backpacks_manager", "get_container", id .. "," .. tostring(GameManager:GetMySNETID()), true)
                    return
                end
                local pos = db.actor:position()
                pos.y = pos.y - 100
                se_inv_box = alife_create("hidden_box", pos, db.actor:level_vertex_id(), db.actor:game_vertex_id())
                if se_inv_box then
                    -- force strictly online (not sure this is needed)
                    alife():set_switch_online(se_inv_box.id, true)
                    alife():set_switch_offline(se_inv_box.id, false)
                    -- Save container
                    m_data.ub_backpack_containers[id] = { id = se_inv_box.id }
                    m_data.ub_backpack_backpacks[se_inv_box.id] = id
                end
            end
            -- Teleport stash to host location
            if se_inv_box then ultimate_backpacks_manager.teleport(se_inv_box) end
            if netid then GameManager:OnICustomScriptAction("ultimate_backpacks_manager", "sync_container", serialize_table_simple(m_data.ub_backpack_backpacks), false, netid) end
            return se_inv_box and se_inv_box or nil
        end
    end
