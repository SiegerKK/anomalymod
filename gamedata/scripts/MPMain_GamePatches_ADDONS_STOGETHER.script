                    local money = raid_utils.money_to_sync[task_id] or 0
                    local cmd = string.format("db.actor:give_money(%d); news_manager.relocate_money(db.actor, 'in', %d)", money, money)
                    GameManager:OnICustomScriptAction(cmd, false)
                    return
                end
                return OGRADTSKFINDA(tsk, task_id)
            end
            OGRADTSKFINDA(tsk, task_id)
