    if agdd_voiced_actor then
        agdd_voiced_actor.actor_speak_client = function (packet)
            for k, v in pairs(db.actors) do
                if v and v.object and v.object:GetNetID() == packet[1] then
                    local snd = sound_object(packet[2])
                    snd.volume = packet[3]
                    snd:play_no_feedback(v.object, 0, 0, v.object:position(), 1.0, 1.0)
                    break
                end
            end
        end
        if agdd_voiced_actor.actor_speak_base then
            agdd_voiced_actor.actor_speak_base = function (file, sound_volume, ...)
                if not (file and db.actor) then return end
                if not OLDACTVOICEN(file, sound_volume, ...) then return end
                -- Sync voice from actor by button or just screams
                local payload = { GameManager:GetMySNETID(), file, sound_volume }
                GameManager:OnICustomScriptAction("agdd_voiced_actor", "actor_speak_client", serialize_table_simple(payload), false)
            end
        else
            agdd_voiced_actor.actor_speak = function (file, sound_volume, ...)
                if not (file and db.actor) then return end
                if not OLDACTVOICEO(file, sound_volume, ...) then return end
                -- Sync voice from actor by button or just screams
                local payload = { GameManager:GetMySNETID(), file, sound_volume }
                GameManager:OnICustomScriptAction("agdd_voiced_actor", "actor_speak_client", serialize_table_simple(payload), false)
            end
        end
    end
    if zz_glowstick_mcm then zz_glowstick_mcm.spawn_glowstick = NOP end -- WERASIK2AA Avoid drop
